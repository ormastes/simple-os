        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", required)
    )
    val annot = _jo3(
        _jp("readOnlyHint", "false"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "false")
    )
    var result = "{"
    result = result + _jp("name", _js("widget_action"))
    result = result + "," + _jp("description", _js("Trigger a UI action on a window (button click, menu select)"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

