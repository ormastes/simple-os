# =========================================================================
# Tool Schemas — Widget Tools
# =========================================================================

fn schema_widget_set() -> text:
    """Schema for widget_set tool."""
    val p_wid = _jo2(
        _jp("type", _js("number")),
        _jp("description", _js("Window ID to set widget tree for"))
    )
    val p_dsl = _jo2(
        _jp("type", _js("string")),
        _jp("description", _js("Widget DSL string. Indentation-based format: column:/row:/panel(title: ...) with text(), button(), progress(), table(), etc."))
    )
    val props = "{" + _jp("window_id", p_wid) + "," + _jp("widget_dsl", p_dsl) + "}"
    val required = "[" + _js("window_id") + "," + _js("widget_dsl") + "]"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", required)
    )
    val annot = _jo3(
        _jp("readOnlyHint", "false"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "true")
    )
    var result = "{"
    result = result + _jp("name", _js("widget_set"))
    result = result + "," + _jp("description", _js("Set window contents using widget DSL. Renders to both GUI and CLI. The DSL supports: column, row, panel, text, label, button, input, progress, table, statusbar, list, checkbox, divider, image, heading."))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

fn schema_widget_read() -> text:
    """Schema for widget_read tool."""
    val p_wid = _jo2(
        _jp("type", _js("number")),
        _jp("description", _js("Window ID to read widget tree from"))
    )
    val props = _jo1(_jp("window_id", p_wid))
    val required = "[" + _js("window_id") + "]"
    val schema = _jo3(
        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", required)
    )
    val annot = _jo3(
        _jp("readOnlyHint", "true"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "true")
    )
    var result = "{"
    result = result + _jp("name", _js("widget_read"))
    result = result + "," + _jp("description", _js("Read current widget tree as text description. LLM can inspect UI state to understand what the user sees."))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

fn schema_widget_action() -> text:
    """Schema for widget_action tool."""
    val p_wid = _jo2(
