        _jp("type", _js("object")),
        _jp("properties", props),
        _jp("required", required)
    )
    val annot = _jo3(
        _jp("readOnlyHint", "true"),
        _jp("destructiveHint", "false"),
        _jp("idempotentHint", "true")
    )
    var result = "{"
    result = result + _jp("name", _js("file_search"))
    result = result + "," + _jp("description", _js("Search files by name pattern in a directory"))
    result = result + "," + _jp("inputSchema", schema)
    result = result + "," + _jp("annotations", annot)
    result = result + "}"
    return result

