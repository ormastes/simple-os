#![allow(unnamed_duplicate_typed_args)]
# Pure Simple GUI — BGA framebuffer on x86_64 QEMU
#
# Proves Simple code can drive the display. BGA init done in Simple
# via extern fn port I/O, rendering delegated to C helper to avoid
# Cranelift stack frame issues with many sequential extern fn calls.

extern fn rt_port_outw(port: u64, value: u64)
extern fn rt_port_inw(port: u64) -> u64
extern fn rt_port_outl(port: u64, value: u64)
extern fn rt_port_inl(port: u64) -> u64
extern fn rt_port_outb(port: u64, value: u64)
extern fn rt_port_inb(port: u64) -> u64
extern fn rt_gui_set_fb(addr: u64, width: u64)
extern fn rt_gui_render_desktop(unused1: u64, unused2: u64)

fn bga_wr(idx: u64, value: u64):
    rt_port_outw(0x01CE, idx)
    rt_port_outw(0x01CF, value)

fn pci_rd(bus: u64, dev: u64, fn_: u64, off: u64) -> u64:
    val a: u64 = 0x80000000 | (bus << 16) | (dev << 11) | (fn_ << 8) | (off & 0xFC)
    rt_port_outl(0x0CF8, a)
    rt_port_inl(0x0CFC)

fn pci_wr(bus: u64, dev: u64, fn_: u64, off: u64, value: u64):
    val a: u64 = 0x80000000 | (bus << 16) | (dev << 11) | (fn_ << 8) | (off & 0xFC)
    rt_port_outl(0x0CF8, a)
    rt_port_outl(0x0CFC, value)

fn find_fb() -> u64:
    var d: u64 = 0
    while d < 32:
        val v = pci_rd(0, d, 0, 0) & 0xFFFF
        if v != 0xFFFF and v != 0:
            val c = pci_rd(0, d, 0, 8)
            if ((c >> 24) & 0xFF) == 3 and ((c >> 16) & 0xFF) == 0:
                # Enable PCI Memory Space + Bus Master
                val cmd = pci_rd(0, d, 0, 0x04)
                pci_wr(0, d, 0, 0x04, cmd | 0x06)
                val b = pci_rd(0, d, 0, 0x10)
                val addr = b & 0xFFFFFFF0
                if addr != 0:
                    return addr
        d = d + 1
    0xFD000000

fn sputc(c: u64):
    while (rt_port_inb(0x3FD) & 0x20) == 0:
        continue
    rt_port_outb(0x3F8, c)

fn sputs(s0: u64, s1: u64, s2: u64, s3: u64, s4: u64, s5: u64, s6: u64, s7: u64):
    if s0 != 0: sputc(s0)
    if s1 != 0: sputc(s1)
    if s2 != 0: sputc(s2)
    if s3 != 0: sputc(s3)
    if s4 != 0: sputc(s4)
    if s5 != 0: sputc(s5)
    if s6 != 0: sputc(s6)
    if s7 != 0: sputc(s7)

fn spl_start():
    # [GUI] init
    sputs(91, 71, 85, 73, 93, 32, 105, 110)
    sputs(105, 116, 13, 10, 0, 0, 0, 0)

    # Program BGA framebuffer: 1024x768x32
    bga_wr(4, 0)
    bga_wr(1, 1024)
    bga_wr(2, 768)
    bga_wr(3, 32)
    bga_wr(6, 1024)
    bga_wr(4, 0x41)

    # Framebuffer address set by C boot code (reads PCI BAR0 = 0xFD000000)
    # Simple's PCI config read has a Cranelift codegen issue with large constants

    # [GUI] draw
    sputs(91, 71, 85, 73, 93, 32, 100, 114)
    sputs(97, 119, 13, 10, 0, 0, 0, 0)

    # Render full desktop in C (avoids Cranelift stack issues)
    rt_gui_render_desktop(0, 0)

    # [GUI] done
    sputs(91, 71, 85, 73, 93, 32, 100, 111)
    sputs(110, 101, 13, 10, 0, 0, 0, 0)
