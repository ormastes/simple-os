#![allow(unnamed_duplicate_typed_args)]
# SimpleOS Glass Window Manager — ARM64 I/O, Render Primitives, Theme
#
# Extracted from wm_entry.spl. Contains:
#   - Extern FFI declarations
#   - UART + ramfb hardware init (ARM64-specific)
#   - Easing / animation math
#   - Rendering primitive helpers (fill, blend, blur, etc.)
#   - Theme-aware color getters
#
# No module-level var state — all functions are pure or hardware-init.

# === Extern FFI declarations ===
extern fn serial_println(msg: text)

# MMIO read/write (ARM64 native -- no port I/O on AArch64)
extern fn rt_mmio_read_u8(addr: u64) -> u64
extern fn rt_mmio_read_u16(addr: u64) -> u64
extern fn rt_mmio_read_u32(addr: u64) -> u64
extern fn rt_mmio_write_u8(addr: u64, value: u64)
extern fn rt_mmio_write_u16(addr: u64, value: u64)
extern fn rt_mmio_write_u32(addr: u64, value: u64)
extern fn rt_mmio_write_u64(addr: u64, value: u64)

# Framebuffer setup
extern fn rt_gui_set_fb(addr: u64, width: u64)

# Glass rendering primitives (from glass_render.c -- architecture-independent)
extern fn rt_gui_begin_frame(width: u64, height: u64, unused1: u64, unused2: u64)
extern fn rt_gui_present(unused1: u64, unused2: u64, unused3: u64, unused4: u64)
extern fn rt_gui_blend_fill(xy: u64, wh: u64, color: u64, alpha: u64)
extern fn rt_gui_box_blur(xy: u64, wh: u64, radius: u64, unused: u64)
extern fn rt_gui_gradient_h(xy: u64, wh: u64, c1: u64, c2: u64)
extern fn rt_gui_gradient_v(xy: u64, wh: u64, c1: u64, c2: u64)
extern fn rt_gui_shadow(xy: u64, wh: u64, blur_alpha: u64, offset: u64)
extern fn rt_gui_rounded_rect(xy: u64, wh: u64, color_radius: u64, alpha: u64)
extern fn rt_gui_shadow_fill(xy: u64, wh: u64, color: u64, unused: u64)
extern fn rt_gui_rounded_rect_top(xy: u64, wh: u64, color_radius: u64, alpha: u64)
extern fn rt_gui_filled_circle(cx_cy: u64, diam_color: u64, alpha: u64, unused: u64)
extern fn rt_gui_draw_wallpaper(wh: u64, style: u64, unused1: u64, unused2: u64)
extern fn rt_gui_rounded_rect_aa(xy: u64, wh: u64, color_radius: u64, alpha: u64)
extern fn rt_gui_line(p1: u64, p2: u64, color_thick: u64, alpha: u64)
extern fn rt_gui_ring(cx_cy: u64, diam_thick: u64, color: u64, alpha: u64)
