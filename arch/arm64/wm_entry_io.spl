# Heap allocation (for framebuffer buffer)
extern fn rt_alloc(size: u64) -> u64

# Pack two u32 values into one u64 (high|low)
fn pack(hi: u64, lo: u64) -> u64:
    (hi << 32) | (lo & 0xFFFFFFFF)

# === Screen dimensions ===
var SCREEN_W: u64 = 1024
var SCREEN_H: u64 = 768
var SYSTEM_BAR_H: u64 = 28
var DOCK_H: u64 = 52
var TITLE_BAR_H: u64 = 44

# ===========================================================================
# PL011 UART Constants (ARM64 QEMU virt)
# ===========================================================================
var PL011_BASE: u64 = 0x09000000
var PL011_DR: u64 = 0x000       # Data Register
var PL011_FR: u64 = 0x018       # Flag Register
var PL011_FR_RXFE: u64 = 0x10   # Receive FIFO empty (bit 4)

# ===========================================================================
# QEMU fw_cfg Constants (for ramfb device configuration)
# ===========================================================================
var FW_CFG_BASE: u64 = 0x09020000   # fw_cfg MMIO on QEMU virt
var FW_CFG_DATA: u64 = 0x000        # Data port (8-bit)
val FW_CFG_SEL: u64  = 0x008        # Selector port (16-bit BE)
val FW_CFG_DMA: u64  = 0x010        # DMA address port (64-bit BE)

