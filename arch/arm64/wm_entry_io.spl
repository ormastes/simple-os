# ===========================================================================
# ARM64 UART Input Helpers
# ===========================================================================

fn uart_data_ready() -> u64:
    """Check if PL011 UART has data available (RXFE=0 means data ready)."""
    val fr = rt_mmio_read_u32(PL011_BASE + PL011_FR)
    if (fr & PL011_FR_RXFE) == 0:
        1
    else:
        0

fn uart_read_char() -> u64:
    """Read a character from PL011 UART data register."""
    rt_mmio_read_u32(PL011_BASE + PL011_DR) & 0xFF

# Action codes returned by uart_char_to_action:
#   0 = None, 1 = CycleFocus, 2 = ToggleTheme, 3 = Quit,
#   4 = Minimize, 5 = Close, 6 = Restore,
#   10 = FocusWindow(0), 11 = FocusWindow(1), 12 = FocusWindow(2)
# Mirrors os.gui.shortcut.uart_char_to_action but uses numeric codes
# so this standalone baremetal file needs no `use` imports.
fn uart_char_to_action(ch: u64) -> u64:
    """Map UART ASCII char to action code."""
    if ch == 9: return 1      # Tab  -> CycleFocus
    if ch == 49: return 10    # '1'  -> FocusWindow(0)
    if ch == 50: return 11    # '2'  -> FocusWindow(1)
    if ch == 51: return 12    # '3'  -> FocusWindow(2)
    if ch == 116: return 2    # 't'  -> ToggleTheme
    if ch == 84: return 2     # 'T'  -> ToggleTheme
    if ch == 113: return 3    # 'q'  -> Quit
    if ch == 81: return 3     # 'Q'  -> Quit
    if ch == 109: return 4    # 'm'  -> Minimize
    if ch == 77: return 4     # 'M'  -> Minimize
    if ch == 119: return 5    # 'w'  -> Close
    if ch == 87: return 5     # 'W'  -> Close
    if ch == 114: return 6    # 'r'  -> Restore
    if ch == 82: return 6     # 'R'  -> Restore
    return 0                  # None

# ===========================================================================
# ARM64 Framebuffer Setup via ramfb
#
# QEMU's ramfb device exposes a simple framebuffer configured via fw_cfg.
# The guest allocates a buffer in RAM, writes a ramfb_cfg structure via
# fw_cfg DMA, and QEMU displays from that address.
#
# ramfb_cfg structure (28 bytes, big-endian):
#   u64 addr     -- physical address of framebuffer
#   u32 fourcc   -- pixel format (DRM_FORMAT_XRGB8888 = 0x34325258)
#   u32 flags    -- 0
#   u32 width    -- display width
#   u32 height   -- display height
#   u32 stride   -- bytes per row (width * 4 for 32bpp)
#
# fw_cfg DMA protocol:
#   1. Select the "etc/ramfb" file via selector port
#   2. Write the config struct via DMA write operation
# ===========================================================================

# Byte-swap helpers for big-endian fw_cfg protocol
fn bswap32(v: u64) -> u64:
    val b0 = (v >> 24) & 0xFF
    val b1 = (v >> 16) & 0xFF
    val b2 = (v >> 8) & 0xFF
    val b3 = v & 0xFF
    (b3 << 24) | (b2 << 16) | (b1 << 8) | b0

fn bswap16(v: u64) -> u64:
    val lo = v & 0xFF
    val hi = (v >> 8) & 0xFF
    (lo << 8) | hi

var FRAMEBUFFER_SIZE: u64 = 3145728   # 1024 * 768 * 4 bytes

fn setup_ramfb(fb_addr: u64) -> u64:
    """Configure QEMU ramfb device to display from fb_addr.

    Uses fw_cfg file enumeration to find 'etc/ramfb' selector,
    then writes the ramfb configuration structure via fw_cfg DMA.

    Returns 1 on success, 0 on failure.
    """
    serial_println("[WM] Configuring ramfb via fw_cfg...")

    # The ramfb file selector is typically 0x0121 on QEMU virt.
    # We enumerate fw_cfg directory to find it reliably.
    #
    # fw_cfg directory is at selector 0x0019:
    #   u32 count (BE) -- number of files
    #   For each file:
    #     u32 size (BE)
    #     u16 selector (BE)
    #     char name[56]

    # Read fw_cfg signature first (selector 0x0000, should return "QEMU")
    rt_mmio_write_u16(0x09020008, 0x0000)
    val sig0 = rt_mmio_read_u8(0x09020000)
    val sig1 = rt_mmio_read_u8(0x09020000)
    val sig2 = rt_mmio_read_u8(0x09020000)
    val sig3 = rt_mmio_read_u8(0x09020000)
    serial_println("[WM] fw_cfg sig: {sig0} {sig1} {sig2} {sig3}")
    # Q=81, E=69, M=77, U=85
    if sig0 != 81:
        serial_println("[WM] fw_cfg signature mismatch (expected Q=81)")

    # Select directory (selector 0x0019)
    rt_mmio_write_u16(0x09020008, bswap16(0x0019))

    # Read file count (4 bytes, big-endian)
    var count: u64 = 0
    var i: u64 = 0
    while i < 4:
        val byte_ = rt_mmio_read_u8(0x09020000)
        count = (count << 8) | (byte_ & 0xFF)
        i = i + 1

    serial_println("[WM] fw_cfg: {count} directory entries")

    if count == 0:
        serial_println("[WM] fw_cfg: count is 0 -- selector may not be working")
        return 0
    if count > 1000:
        serial_println("[WM] fw_cfg: count too large -- endianness issue?")
        return 0

    # Search for "etc/ramfb" in directory
    var ramfb_sel: u64 = 0
    var found: u64 = 0
    var idx: u64 = 0
    while idx < count:
        if idx > 200:
            idx = count   # safety limit

        # Read file size (4 bytes BE)
        var fsize: u64 = 0
        var j: u64 = 0
        while j < 4:
            val b = rt_mmio_read_u8(0x09020000)
            fsize = (fsize << 8) | (b & 0xFF)
            j = j + 1

        # Read selector (2 bytes BE)
        var sel: u64 = 0
        j = 0
        while j < 2:
            val b = rt_mmio_read_u8(0x09020000)
            sel = (sel << 8) | (b & 0xFF)
            j = j + 1

        # Skip reserved (2 bytes)
        rt_mmio_read_u8(0x09020000)
        rt_mmio_read_u8(0x09020000)

        # Read name (56 bytes)
        var name_match: u64 = 1
        # "etc/ramfb" = 101,116,99,47,114,97,109,102,98,0
        val expected_0: u64 = 101  # 'e'
        val expected_1: u64 = 116  # 't'
        val expected_2: u64 = 99   # 'c'
        val expected_3: u64 = 47   # '/'
        val expected_4: u64 = 114  # 'r'
        val expected_5: u64 = 97   # 'a'
        val expected_6: u64 = 109  # 'm'
        val expected_7: u64 = 102  # 'f'
        val expected_8: u64 = 98   # 'b'

        var c0: u64 = 0
        var c1_ch: u64 = 0
        var c2_ch: u64 = 0
        var c3_ch: u64 = 0
        j = 0
        while j < 56:
            val ch = rt_mmio_read_u8(0x09020000) & 0xFF
            if j == 0: c0 = ch
            if j == 1: c1_ch = ch
            if j == 2: c2_ch = ch
            if j == 3: c3_ch = ch
            if j == 0 and ch != expected_0: name_match = 0
            if j == 1 and ch != expected_1: name_match = 0
            if j == 2 and ch != expected_2: name_match = 0
            if j == 3 and ch != expected_3: name_match = 0
            if j == 4 and ch != expected_4: name_match = 0
            if j == 5 and ch != expected_5: name_match = 0
            if j == 6 and ch != expected_6: name_match = 0
            if j == 7 and ch != expected_7: name_match = 0
            if j == 8 and ch != expected_8: name_match = 0
            if j == 9 and ch != 0: name_match = 0
            j = j + 1

        if name_match == 1:
            ramfb_sel = sel
            found = 1
            serial_println("[WM] Found etc/ramfb in fw_cfg")

        idx = idx + 1

    if found == 0:
        serial_println("[WM] WARNING: etc/ramfb not found -- add -device ramfb to QEMU")
        return 0

    # Write ramfb configuration via fw_cfg DMA
    #
    # ramfb_cfg (28 bytes, all big-endian):
    #   u64 addr     = fb_addr
    #   u32 fourcc   = 0x34325258 (XR24 = DRM_FORMAT_XRGB8888)
    #   u32 flags    = 0
    #   u32 width    = 1024
    #   u32 height   = 768
    #   u32 stride   = 4096 (1024 * 4)

    # Allocate config buffer (28 bytes, write manually)
    val cfg_buf = rt_alloc(32)
    if cfg_buf == 0:
        serial_println("[WM] Failed to allocate ramfb config buffer")
        return 0

    # Write big-endian fields to config buffer
    # addr (8 bytes BE)
    val addr_ptr = cfg_buf
    rt_mmio_write_u8(addr_ptr + 0, (fb_addr >> 56) & 0xFF)
    rt_mmio_write_u8(addr_ptr + 1, (fb_addr >> 48) & 0xFF)
    rt_mmio_write_u8(addr_ptr + 2, (fb_addr >> 40) & 0xFF)
    rt_mmio_write_u8(addr_ptr + 3, (fb_addr >> 32) & 0xFF)
    rt_mmio_write_u8(addr_ptr + 4, (fb_addr >> 24) & 0xFF)
    rt_mmio_write_u8(addr_ptr + 5, (fb_addr >> 16) & 0xFF)
    rt_mmio_write_u8(addr_ptr + 6, (fb_addr >> 8) & 0xFF)
    rt_mmio_write_u8(addr_ptr + 7, fb_addr & 0xFF)

    # fourcc (4 bytes BE) = 0x34325258
    rt_mmio_write_u8(addr_ptr + 8, 0x34)
    rt_mmio_write_u8(addr_ptr + 9, 0x32)
    rt_mmio_write_u8(addr_ptr + 10, 0x52)
    rt_mmio_write_u8(addr_ptr + 11, 0x58)

    # flags (4 bytes BE) = 0
    rt_mmio_write_u8(addr_ptr + 12, 0)
    rt_mmio_write_u8(addr_ptr + 13, 0)
    rt_mmio_write_u8(addr_ptr + 14, 0)
    rt_mmio_write_u8(addr_ptr + 15, 0)

    # width (4 bytes BE) = 1024 = 0x00000400
    rt_mmio_write_u8(addr_ptr + 16, 0)
    rt_mmio_write_u8(addr_ptr + 17, 0)
    rt_mmio_write_u8(addr_ptr + 18, 0x04)
    rt_mmio_write_u8(addr_ptr + 19, 0x00)

    # height (4 bytes BE) = 768 = 0x00000300
    rt_mmio_write_u8(addr_ptr + 20, 0)
    rt_mmio_write_u8(addr_ptr + 21, 0)
    rt_mmio_write_u8(addr_ptr + 22, 0x03)
    rt_mmio_write_u8(addr_ptr + 23, 0x00)

    # stride (4 bytes BE) = 4096 = 0x00001000
    rt_mmio_write_u8(addr_ptr + 24, 0)
    rt_mmio_write_u8(addr_ptr + 25, 0)
    rt_mmio_write_u8(addr_ptr + 26, 0x10)
    rt_mmio_write_u8(addr_ptr + 27, 0x00)

    # DEBUG: verify cfg_buf content + selector before DMA
    val dbg_w2 = rt_mmio_read_u8(addr_ptr + 18)
    val dbg_w3 = rt_mmio_read_u8(addr_ptr + 19)
    val dbg_h2 = rt_mmio_read_u8(addr_ptr + 22)
    val dbg_f0 = rt_mmio_read_u8(addr_ptr + 8)
    serial_println("[WM] DBG sel={ramfb_sel} cfg=({dbg_f0}) w=({dbg_w2},{dbg_w3}) h=({dbg_h2}) cfg_buf={cfg_buf} fb={fb_addr}")

    # Select the ramfb file
    rt_mmio_write_u16(0x09020008, bswap16(ramfb_sel))

    # Write config via DMA
    val dma_desc = rt_alloc(16)
    if dma_desc == 0:
        serial_println("[WM] Failed to allocate DMA descriptor")
        return 0

    # control (4 bytes BE) = (ramfb_sel << 16) | 0x18
    val ctrl = (ramfb_sel << 16) | 0x18
    rt_mmio_write_u8(dma_desc + 0, (ctrl >> 24) & 0xFF)
    rt_mmio_write_u8(dma_desc + 1, (ctrl >> 16) & 0xFF)
    rt_mmio_write_u8(dma_desc + 2, (ctrl >> 8) & 0xFF)
    rt_mmio_write_u8(dma_desc + 3, ctrl & 0xFF)

    # length (4 bytes BE) = 28
    rt_mmio_write_u8(dma_desc + 4, 0)
    rt_mmio_write_u8(dma_desc + 5, 0)
    rt_mmio_write_u8(dma_desc + 6, 0)
    rt_mmio_write_u8(dma_desc + 7, 28)

    # address (8 bytes BE) = cfg_buf (physical address of config data)
    rt_mmio_write_u8(dma_desc + 8, (cfg_buf >> 56) & 0xFF)
    rt_mmio_write_u8(dma_desc + 9, (cfg_buf >> 48) & 0xFF)
    rt_mmio_write_u8(dma_desc + 10, (cfg_buf >> 40) & 0xFF)
    rt_mmio_write_u8(dma_desc + 11, (cfg_buf >> 32) & 0xFF)
    rt_mmio_write_u8(dma_desc + 12, (cfg_buf >> 24) & 0xFF)
    rt_mmio_write_u8(dma_desc + 13, (cfg_buf >> 16) & 0xFF)
    rt_mmio_write_u8(dma_desc + 14, (cfg_buf >> 8) & 0xFF)
    rt_mmio_write_u8(dma_desc + 15, cfg_buf & 0xFF)

    # Trigger DMA: write descriptor address to FW_CFG_DMA register (big-endian u64)
    rt_mmio_write_u32(0x09020010, bswap32((dma_desc >> 32) & 0xFFFFFFFF))
    rt_mmio_write_u32(0x09020014, bswap32(dma_desc & 0xFFFFFFFF))

    # Wait for DMA completion. The control word is the first 4 bytes of the
    # descriptor in BIG-ENDIAN: read all four bytes, not just byte 0. (Byte 0 is
    # the MSB, which is always 0 for the small etc/ramfb selector, so a byte-0
    # check reports success immediately even when the DMA never ran or errored.)
    # QEMU clears the control word to 0 on success and sets bit 0 on error.
    var timeout: u64 = 0
    while timeout < 1000000:
        val c0 = rt_mmio_read_u8(dma_desc + 0)
        val c1 = rt_mmio_read_u8(dma_desc + 1)
        val c2 = rt_mmio_read_u8(dma_desc + 2)
        val c3 = rt_mmio_read_u8(dma_desc + 3)
        val ctrl_now = (c0 << 24) | (c1 << 16) | (c2 << 8) | c3
        if ctrl_now == 0:
            serial_println("[WM] ramfb configured successfully via fw_cfg DMA")
            return 1
        if (ctrl_now & 0x01) != 0:
            serial_println("[WM] ramfb DMA ERROR: fw_cfg rejected config (ctrl bit0 set)")
            return 0
        timeout = timeout + 1

    serial_println("[WM] ramfb DMA timeout -- DMA never completed (ctrl word nonzero)")
    return 0   # Surface the failure instead of falsely reporting success

# ===========================================================================
# Easing / Animation Functions
# ===========================================================================

fn bounce_offset(progress: u64) -> u64:
    if progress < 40:
        (8 * (40 - progress)) / 40
    else:
        if progress < 70:
            0
        else:
            0

fn ease_out_cubic(t: u64) -> u64:
    val inv = 100 - t
    val inv2 = inv * inv / 100
    val inv3 = inv2 * inv / 100
    100 - inv3

fn ease_in_out_quad(t: u64) -> u64:
    if t < 50:
        t * t * 2 / 100
    else:
        val inv = 100 - t
        100 - inv * inv * 2 / 100

fn spring_ease(t: u64) -> u64:
    if t < 60:
        t * 110 / 60
    else:
        if t < 80:
            110 - (t - 60) * 15 / 20
        else:
            95 + (t - 80) * 5 / 20

fn ease_in_cubic(t: u64) -> u64:
    t * t * t / 10000

fn lerp(start: u64, end_: u64, progress: u64) -> u64:
    if end_ >= start:
        start + (end_ - start) * progress / 100
    else:
        start - (start - end_) * progress / 100

