# RISC-V 32 Entry — Boot shim for RV32 QEMU virt (M-mode, no OpenSBI)
#
# Performs REAL hardware initialization:
# 1. 16550 UART init via MMIO at 0x10000000 (real register writes)
# 2. QEMU virt memory map construction (RAM at 0x80000000)
# 3. Hands off to kernel_main() which runs real PMM + scheduler code
#
# Boots directly in M-mode with -bios none (no OpenSBI firmware).

use os.kernel.boot.mmio.{mmio_write8, mmio_read8}

# Direct UART output — bypasses all string allocation
fn uart_putc(ch: u8):
    # Wait until TX empty (LSR bit 5)
    while (mmio_read8(0x10000005) & 0x20) == 0:
        pass_do_nothing
    mmio_write8(0x10000000, ch as u64)

fn uart_puts(msg: text):
    var i = 0
    while i < msg.len():
        val ch = msg.char_at(i)
        uart_putc(ch as u8)
        i = i + 1

fn kernel_main():
    pass_do_nothing

fn _start():
    """RISC-V 32 entry point — M-mode direct boot (no OpenSBI)."""
    # Write 'S' directly to UART to verify basic MMIO works
    uart_putc(0x53)   # 'S'
    uart_putc(0x0A)   # newline
    uart_puts("SimpleOS RV32 boot OK")
    uart_putc(0x0A)
