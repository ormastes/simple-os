fn draw_page_network(x: u64, y: u64, w: u64, h: u64, theme: u64):
    """Render the network status page (about:network)."""
    val text_color = text_c(theme)
    val dim_color = text_sec(theme)
    val heading_color = text_color
    val red: u64 = 0x00FF3B30

    # Title in vector type
    draw_label_vector(x + 10, y + 9, heading_color, 240, pack8(78, 101, 116, 119, 111, 114, 107, 32), 8, 18)
    draw_label_vector(x + 74, y + 9, heading_color, 240, pack8(83, 116, 97, 116, 117, 115, 0, 0), 6, 18)
    blend(x + 10, y + 28, w - 20, 1, dim_color, 40)

    # Interface status
    val sy = y + 40
    # "Interfac" = 73,110,116,101,114,102,97,99
    draw_label_vector(x + 20, sy, text_color, 180, pack8(73, 110, 116, 101, 114, 102, 97, 99), 8, 14)
    # "e: eth0" = 101,58,32,101,116,104,48
    draw_label_vector(x + 84, sy, text_color, 180, pack8(101, 58, 32, 101, 116, 104, 48, 0), 7, 14)

    # Status indicator (red circle = disconnected)
    circle(x + 20, sy + 22, 8, red, 200)
    # "Status: " = 83,116,97,116,117,115,58,32
    draw_label_vector(x + 34, sy + 20, red, 210, pack8(83, 116, 97, 116, 117, 115, 58, 32), 8, 14)
    # "Not conn" = 78,111,116,32,99,111,110,110
    draw_label_vector(x + 98, sy + 20, red, 210, pack8(78, 111, 116, 32, 99, 111, 110, 110), 8, 14)
    # "ected" = 101,99,116,101,100
    draw_label_vector(x + 162, sy + 20, red, 210, pack8(101, 99, 116, 101, 100, 0, 0, 0), 5, 14)

    # "Driver: " = 68,114,105,118,101,114,58,32
    draw_label_vector(x + 20, sy + 42, text_color, 180, pack8(68, 114, 105, 118, 101, 114, 58, 32), 8, 14)
    # "VirtIO-n" = 86,105,114,116,73,79,45,110
    draw_label_vector(x + 84, sy + 42, text_color, 180, pack8(86, 105, 114, 116, 73, 79, 45, 110), 8, 14)
    # "et" = 101,116
    draw_label_vector(x + 148, sy + 42, text_color, 180, pack8(101, 116, 0, 0, 0, 0, 0, 0), 2, 14)

    # "MAC: 52:" = 77,65,67,58,32,53,50,58
    draw_label_vector(x + 20, sy + 62, dim_color, 160, pack8(77, 65, 67, 58, 32, 53, 50, 58), 8, 14)
    # "54:00:12" = 53,52,58,48,48,58,49,50
    draw_label_vector(x + 84, sy + 62, dim_color, 160, pack8(53, 52, 58, 48, 48, 58, 49, 50), 8, 14)
    # ":34:56" = 58,51,52,58,53,54
    draw_label_vector(x + 148, sy + 62, dim_color, 160, pack8(58, 51, 52, 58, 53, 54, 0, 0), 6, 14)

    # Note about networking
    val ny = sy + 92
    # "To enabl" = 84,111,32,101,110,97,98,108
    draw_label_vector(x + 10, ny + 1, heading_color, 200, pack8(84, 111, 32, 101, 110, 97, 98, 108), 8, 16)
    # "e networ" = 101,32,110,101,116,119,111,114
    draw_label_vector(x + 74, ny + 1, heading_color, 200, pack8(101, 32, 110, 101, 116, 119, 111, 114), 8, 16)
    # "king:" = 107,105,110,103,58
    draw_label_vector(x + 138, ny + 1, heading_color, 200, pack8(107, 105, 110, 103, 58, 0, 0, 0), 5, 16)

    # "Add -net" = 65,100,100,32,45,110,101,116
    draw_label_vector(x + 20, ny + 20, text_color, 180, pack8(65, 100, 100, 32, 45, 110, 101, 116), 8, 14)
    # "dev user" = 100,101,118,32,117,115,101,114
    draw_label_vector(x + 84, ny + 20, text_color, 180, pack8(100, 101, 118, 32, 117, 115, 101, 114), 8, 14)
    # " to QEMU" = 32,116,111,32,81,69,77,85
    draw_label_vector(x + 148, ny + 20, text_color, 180, pack8(32, 116, 111, 32, 81, 69, 77, 85), 8, 14)

    # Packet counters
    val py = ny + 50
    # "Packets" = 80,97,99,107,101,116,115
    draw_label_vector(x + 10, py + 1, heading_color, 200, pack8(80, 97, 99, 107, 101, 116, 115, 0), 7, 16)
    # "TX: 0  R" = 84,88,58,32,48,32,32,82
    draw_label_vector(x + 20, py + 20, dim_color, 160, pack8(84, 88, 58, 32, 48, 32, 32, 82), 8, 14)
    # "X: 0  Dr" = 88,58,32,48,32,32,68,114
    draw_label_vector(x + 84, py + 20, dim_color, 160, pack8(88, 58, 32, 48, 32, 32, 68, 114), 8, 14)
    # "opped: 0" = 111,112,112,101,100,58,32,48
    draw_label_vector(x + 148, py + 20, dim_color, 160, pack8(111, 112, 112, 101, 100, 58, 32, 48), 8, 14)

    # Back link: "< Back t" = 60,32,66,97,99,107,32,116
    draw_label_vector(x + 20, py + 50, 0x000A84FF, 220, pack8(60, 32, 66, 97, 99, 107, 32, 116), 8, 14)
    # "o Home" = 111,32,72,111,109,101
    draw_label_vector(x + 84, py + 50, 0x000A84FF, 220, pack8(111, 32, 72, 111, 109, 101, 0, 0), 6, 14)

# ===========================================================================
# Window Title Drawing
# ===========================================================================

fn draw_window_title(x: u64, y: u64, w: u64, title_chars: u64, title_len: u64, theme: u64):
    val title_pixel_w = title_len * 10
    val text_x = x + (w - title_pixel_w) / 2
    val text_y = y + 14
    # Multi-shadow depth for premium typography (second pass — softer, offset further)
    draw_label_vector(text_x + 1, text_y + 2, 0x00000000, 12, title_chars, title_len, 18)
    # Dark text shadow for crisp contrast (premium typography depth)
    draw_label_vector(text_x + 1, text_y + 1, 0x00000000, 45, title_chars, title_len, 18)
    # Vector font at 18px height — clean, centered, premium look
    draw_label_vector(text_x, text_y, text_c(theme), 240, title_chars, title_len, 18)

fn draw_window_card(x: u64, y: u64, w: u64, h: u64, is_active: u64, theme: u64, title_chars: u64, title_len: u64):
    val body_color = if theme == 0: 0x001B1F2B else: 0x00FCF7FF
    val body_alpha = if theme == 0: 210 else: 235
    val border_alpha = if is_active == 1: 90 else: 45
    val title_alpha = if theme == 0: 150 else: 205
    val title_color = if theme == 0: 0x00262C3A else: 0x00F0E8F9
    rrect_aa(x, y, w, h, body_color, WIN_CORNER_RADIUS, body_alpha)
    rrect_aa(x, y, w, h, border_c(theme), WIN_CORNER_RADIUS, border_alpha)
    blend(x + 1, y + 1, w - 2, TITLE_BAR_H, title_color, title_alpha)
    blend(x + 14, y + TITLE_BAR_H - 1, w - 28, 1, border_c(theme), 24)
    if is_active == 1:
        grad_h(x + 18, y + 6, w - 36, 2, accent(theme), accent2(theme))
    # Traffic-light dots
    circle(x + BTN_MARGIN_X, y + BTN_MARGIN_Y, 12, BTN_CLOSE, 170)
    circle(x + BTN_MARGIN_X + BTN_GAP + 10, y + BTN_MARGIN_Y, 12, BTN_MIN, 170)
    circle(x + BTN_MARGIN_X + 2 * (BTN_GAP + 10), y + BTN_MARGIN_Y, 12, BTN_MAX, 170)
    draw_window_title(x, y, w, title_chars, title_len, theme)

# ===========================================================================
# Animation Helpers
# ===========================================================================

# Get dock icon X position for minimize target (window -> dock icon slot)
fn dock_icon_x(win_idx: u64) -> u64:
    val num_icons: u64 = 7
    val pill_w = DOCK_PILL_SIZE
    val icon_gap = DOCK_ICON_GAP
    val dock_pad = DOCK_H_PAD
    val separator_w: u64 = 2
    val separator_gap: u64 = 10
    val num_util_icons: u64 = 2
    val dock_w = num_icons * (pill_w + icon_gap) + separator_w + separator_gap * 2 + num_util_icons * (pill_w + icon_gap) - icon_gap + dock_pad * 2
    val dock_x = (SCREEN_W - dock_w) / 2
    # Map window index to icon position (win0=terminal=icon0, win1=editor=icon6, win2=files=icon1)
    if win_idx == 0:
        dock_x + dock_pad + pill_w / 2
    else:
        if win_idx == 1:
            dock_x + dock_pad + 6 * (pill_w + icon_gap) + pill_w / 2
        else:
            dock_x + dock_pad + 1 * (pill_w + icon_gap) + pill_w / 2

fn dock_icon_y() -> u64:
    SCREEN_H - DOCK_ACTUAL_H - DOCK_MARGIN_BOTTOM + 8

# Draw window scaled between two rectangles based on progress
fn draw_animated_window(
    src_x: u64, src_y: u64, src_w: u64, src_h: u64,
    dst_x: u64, dst_y: u64, dst_w: u64, dst_h: u64,
    progress: u64, theme: u64):
    val eased = ease_out_cubic(progress)
    val ax = lerp(src_x, dst_x, eased)
    val ay = lerp(src_y, dst_y, eased)
    val aw = lerp(src_w, dst_w, eased)
    val ah = lerp(src_h, dst_h, eased)
    # Only draw if size is reasonable
    if aw > 20 and ah > 20:
        draw_glass_window(ax, ay, aw, ah, 1, theme)

# ===========================================================================
# Full Desktop Rendering
# ===========================================================================

fn draw_win0_normal(boff: u64, is_active: u64, theme: u64):
    val by = WIN0_Y - boff
    draw_glass_window(WIN0_X, by, WIN0_W, WIN0_H, is_active, theme)
    draw_terminal_content(WIN0_X, by, WIN0_W, WIN0_H, theme)
    draw_window_title(WIN0_X, by, WIN0_W, pack8(84, 101, 114, 109, 105, 110, 97, 108), 8, theme)

fn draw_win1_normal(boff: u64, is_active: u64, theme: u64):
    val by = WIN1_Y - boff
    draw_glass_window(WIN1_X, by, WIN1_W, WIN1_H, is_active, theme)
    draw_hello_content(WIN1_X, by, WIN1_W, WIN1_H, theme)
    draw_window_title(WIN1_X, by, WIN1_W, pack8(69, 100, 105, 116, 111, 114, 0, 0), 6, theme)

fn draw_win2_normal(boff: u64, is_active: u64, theme: u64):
    val by = WIN2_Y - boff
    draw_glass_window(WIN2_X, by, WIN2_W, WIN2_H, is_active, theme)
    draw_browser_content(WIN2_X, by, WIN2_W, WIN2_H, theme)
    draw_window_title(WIN2_X, by, WIN2_W, pack8(66, 114, 111, 119, 115, 101, 114, 0), 7, theme)

# Draw close animation: scale down to center + fade
fn draw_close_animated(wx: u64, wy: u64, ww: u64, wh: u64, theme: u64):
    val eased = ease_in_cubic(g_close_progress)
    val shrink = eased * 15 / 100
    val cx = wx + shrink * ww / 200
    val cy = wy + shrink * wh / 200
    val cw = ww - shrink * ww / 100
    val ch = wh - shrink * wh / 100
    if cw > 30 and ch > 30:
        draw_glass_window(cx, cy, cw, ch, 1, theme)

# Draw a single window: normal, animating-minimize, animating-close, or skip if minimized
fn draw_single_window(win: u64, boff: u64, is_active: u64, theme: u64):
    val minimized_bit = (g_minimize_states >> win) & 1
    # If being actively minimized, draw animated version
    if g_minimize_active == 1 and g_minimize_win == win:
        if win == 0:
            draw_animated_window(WIN0_X, WIN0_Y, WIN0_W, WIN0_H, dock_icon_x(0), dock_icon_y(), 48, 48, g_minimize_progress, theme)
        else:
            if win == 1:
                draw_animated_window(WIN1_X, WIN1_Y, WIN1_W, WIN1_H, dock_icon_x(1), dock_icon_y(), 48, 48, g_minimize_progress, theme)
            else:
                draw_animated_window(WIN2_X, WIN2_Y, WIN2_W, WIN2_H, dock_icon_x(2), dock_icon_y(), 48, 48, g_minimize_progress, theme)
    else:
        # If being actively closed, draw close animation
        if g_close_active == 1 and g_close_win == win:
            if win == 0:
                draw_close_animated(WIN0_X, WIN0_Y, WIN0_W, WIN0_H, theme)
            else:
                if win == 1:
                    draw_close_animated(WIN1_X, WIN1_Y, WIN1_W, WIN1_H, theme)
                else:
                    draw_close_animated(WIN2_X, WIN2_Y, WIN2_W, WIN2_H, theme)
        else:
            # Skip if already minimized
            if minimized_bit == 0:
                if win == 0:
                    draw_win0_normal(boff, is_active, theme)
                else:
                    if win == 1:
                        draw_win1_normal(boff, is_active, theme)
                    else:
                        draw_win2_normal(boff, is_active, theme)

fn draw_desktop(active: u64, theme: u64):
    # Begin frame
    rt_gui_begin_frame(SCREEN_W, SCREEN_H, 0, 0)

    # 1. Desktop wallpaper
    # `rt_gui_draw_wallpaper` is safe during boot splash, but on the x86 WM
    # path it can stall after `begin_frame`. Keep the desktop background local
    # to the WM render path so the first compositor frame always completes.
    if theme == 0:
        grad_v(0, 0, SCREEN_W, SCREEN_H, DARK_BG_TOP, DARK_BG_BOT)
        blend(0, 0, SCREEN_W, SCREEN_H, 0x00040A18, 26)
        blend(0, SCREEN_H / 2, SCREEN_W, SCREEN_H / 2, 0x00140A22, 18)
    else:
        grad_v(0, 0, SCREEN_W, SCREEN_H, LIGHT_BG_TOP, LIGHT_BG_BOT)
        blend(0, SCREEN_H / 3, SCREEN_W, SCREEN_H * 2 / 3, 0x00FFF6FB, 18)

    val boff = bounce_offset(g_anim_progress)

    # Lightweight window shells keep the WM usable on x86 while richer
    # content views are validated separately.
    if active == 0:
        draw_window_card(WIN2_X, WIN2_Y, WIN2_W, WIN2_H, 0, theme, pack8(66, 114, 111, 119, 115, 101, 114, 0), 7)
        draw_window_card(WIN1_X, WIN1_Y, WIN1_W, WIN1_H, 0, theme, pack8(69, 100, 105, 116, 111, 114, 0, 0), 6)
        draw_window_card(WIN0_X, WIN0_Y - boff, WIN0_W, WIN0_H, 1, theme, pack8(84, 101, 114, 109, 105, 110, 97, 108), 8)
    else:
        if active == 1:
            draw_window_card(WIN2_X, WIN2_Y, WIN2_W, WIN2_H, 0, theme, pack8(66, 114, 111, 119, 115, 101, 114, 0), 7)
            draw_window_card(WIN0_X, WIN0_Y, WIN0_W, WIN0_H, 0, theme, pack8(84, 101, 114, 109, 105, 110, 97, 108), 8)
            draw_window_card(WIN1_X, WIN1_Y - boff, WIN1_W, WIN1_H, 1, theme, pack8(69, 100, 105, 116, 111, 114, 0, 0), 6)
        else:
            draw_window_card(WIN0_X, WIN0_Y, WIN0_W, WIN0_H, 0, theme, pack8(84, 101, 114, 109, 105, 110, 97, 108), 8)
            draw_window_card(WIN1_X, WIN1_Y, WIN1_W, WIN1_H, 0, theme, pack8(69, 100, 105, 116, 111, 114, 0, 0), 6)
            draw_window_card(WIN2_X, WIN2_Y - boff, WIN2_W, WIN2_H, 1, theme, pack8(66, 114, 111, 119, 115, 101, 114, 0), 7)

    # Present — bulk-copy shadow buffer to MMIO framebuffer
    rt_gui_present(0, 0, 0, 0)

# ===========================================================================
# Entry Point
# ===========================================================================

fn spl_start():
    serial_println("[WM] SimpleOS Glass Window Manager starting...")

    # 1. Program BGA framebuffer
    serial_println("[WM] Programming BGA: 1024x768x32")
    bga_wr(4, 0)
    bga_wr(1, SCREEN_W)
    bga_wr(2, SCREEN_H)
    bga_wr(3, 32)
    bga_wr(6, SCREEN_W)
    bga_wr(4, 0x41)

    # 2. Find framebuffer
    serial_println("[WM] Scanning PCI for VGA...")
    val fb_addr = find_vga_fb()
    rt_gui_set_fb(fb_addr, SCREEN_W)

    # Boot splash screen
    serial_println("[WM] Showing boot splash...")
    rt_gui_begin_frame(SCREEN_W, SCREEN_H, 0, 0)

    # Dark gradient background
    rt_gui_draw_wallpaper(pack(SCREEN_W, SCREEN_H), 0, 0, 0)

    # Center logo area — large rounded glass pill (wider for 2x text)
    val splash_w: u64 = 300
    val splash_h: u64 = 140
    val splash_x = (SCREEN_W - splash_w) / 2
    val splash_y = (SCREEN_H - splash_h) / 2 - 40

    # Glass logo container
    blur(splash_x, splash_y, splash_w, splash_h, 24)
    rrect_aa(splash_x, splash_y, splash_w, splash_h, 0x001E1E23, 28, 140)
    blend(splash_x + 4, splash_y + 1, splash_w - 8, 1, 0x00FFFFFF, 40)
    blend(splash_x + 6, splash_y + 2, splash_w - 12, 1, 0x00FFFFFF, 20)
    rrect_aa(splash_x, splash_y, splash_w, splash_h, 0x00FFFFFF, 28, 25)

    # "SimpleOS" in vector font at 40px
    draw_label_vector(splash_x + 70, splash_y + 16, 0x00F5F5F7, 240, pack8(83, 105, 109, 112, 108, 101, 79, 83), 8, 40)

    # Version text below (vector with soft shadow)
    draw_label_vector(splash_x + 131, splash_y + 61, 0x00000000, 40, pack8(118, 49, 46, 48, 0, 0, 0, 0), 4, 16)
    draw_label_vector(splash_x + 130, splash_y + 60, 0x00EBEBF5, 160, pack8(118, 49, 46, 48, 0, 0, 0, 0), 4, 16)

    # Loading bar (wider, more visible)
    val bar_y = splash_y + 90
    rrect_aa(splash_x + 40, bar_y, splash_w - 80, 8, 0x00FFFFFF, 4, 30)
    grad_h(splash_x + 40, bar_y + 1, (splash_w - 80) * 2 / 3, 6, DARK_ACCENT, DARK_ACCENT2)
    rrect_aa(splash_x + 40, bar_y, (splash_w - 80) * 2 / 3, 8, 0x00FFFFFF, 4, 20)

    # "Starting..." below (vector with soft shadow)
    draw_label_vector((SCREEN_W - 72) / 2 + 1, splash_y + splash_h + 21, 0x00000000, 30, pack8(83, 116, 97, 114, 116, 105, 110, 103), 8, 14)
    draw_label_vector((SCREEN_W - 72) / 2, splash_y + splash_h + 20, 0x00EBEBF5, 120, pack8(83, 116, 97, 114, 116, 105, 110, 103), 8, 14)

    # SimpleOS branding: "Powered " tagline in vector
    draw_label_vector(splash_x + 56, splash_y + splash_h + 40, 0x00EBEBF5, 60, pack8(80, 111, 119, 101, 114, 101, 100, 32), 8, 12)

    rt_gui_present(0, 0, 0, 0)

    # Brief pause to show splash (busy wait)
    var splash_wait: u64 = 0
    while splash_wait < 2000000:
        splash_wait = splash_wait + 1

    # 3. Initial render (dark glass theme)
    var theme: u64 = 0  # 0=dark, 1=light
    var active_win: u64 = 1

    # Animation state
    var anim_frame: u64 = 0       # Frame counter
    var anim_start: u64 = 0       # Frame when animation started
    var anim_duration: u64 = 12   # Animation length in frames
    var animating: u64 = 0        # 1 if currently animating
    var needs_redraw: u64 = 1     # Redraw on next frame
    var idle_count: u64 = 0       # Frames since last activity

    # Initialize PS/2 mouse
    mouse_init()

    # Initialize browser to about:home
    browser_navigate(0)
    # Set default URL text to "about:home"
    # a=97,b=98,o=111,u=117,t=116,:=58,h=104,o=111,m=109,e=101
    g_browser_url_0 = pack8(97, 98, 111, 117, 116, 58, 104, 111)
    g_browser_url_1 = pack8(109, 101, 0, 0, 0, 0, 0, 0)
    g_browser_url_len = 10

    # Local scancode-to-action mapping (matches os.gui.shortcut convention)

    serial_println("[WM] Rendering glass desktop (dark theme)...")
    draw_desktop(active_win, theme)

    serial_println("[WM] Glass desktop rendered!")
    serial_println("[WM] Controls: Tab=cycle, 1/2/3=focus, T=theme, M=minimize, R=restore, Q=quit")

    # 4. Continuous render loop with animation
    var running: u64 = 1
    while running == 1:
        # Update terminal input active state based on focused window
        if active_win == 0:
            g_term_input_active = 1
        else:
            g_term_input_active = 0

        # Poll keyboard — drain all pending PS/2 data
        var kb_poll_count: u64 = 0
        while (io_inb(0x64) & 1) != 0 and kb_poll_count < 16:
            val scancode = io_inb(0x60)
            kb_poll_count = kb_poll_count + 1
            if (scancode & 0x80) == 0:
                # Determine which WM shortcut (if any) this scancode maps to
                # Tab and number keys always work; letter shortcuts only when
                # the terminal is NOT in input mode (active_win != 0)
                var wm_shortcut: u64 = 0
                if scancode == 0x0F: wm_shortcut = 1  # Tab always works
                if scancode == 0x02: wm_shortcut = 2  # 1 always works
                if scancode == 0x03: wm_shortcut = 3  # 2 always works
                if scancode == 0x04: wm_shortcut = 4  # 3 always works
                # T/Q/M/W/R only work as shortcuts when NOT typing in terminal or editor
                if g_term_input_active == 0 and g_ed_editing == 0:
                    if scancode == 0x14: wm_shortcut = 5  # T = theme
                    if scancode == 0x10: wm_shortcut = 6  # Q = quit
                    if scancode == 0x32: wm_shortcut = 7  # M = minimize
                    if scancode == 0x11: wm_shortcut = 8  # W = close
                    if scancode == 0x13: wm_shortcut = 9  # R = restore

                # Process WM shortcuts
                if wm_shortcut == 1:
                    # Tab = cycle focus
                    active_win = (active_win + 1) % 3
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                    serial_println("[WM] Focus cycled")
                if wm_shortcut == 2:
                    active_win = 0
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                if wm_shortcut == 3:
                    active_win = 1
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                if wm_shortcut == 4:
                    active_win = 2
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                if wm_shortcut == 5:
                    # T = toggle theme
                    theme = (theme + 1) % 2
                    animating = 1
                    anim_start = anim_frame
                    g_anim_progress = 0
                    needs_redraw = 1
                    if theme == 0:
                        serial_println("[WM] Theme: Dark Glass")
                    else:
                        serial_println("[WM] Theme: White Glass")
                if wm_shortcut == 6:
                    # Q = quit
                    running = 0
                    serial_println("[WM] Quit requested")
                if wm_shortcut == 7:
                    # M = minimize
                    val already_minimized = (g_minimize_states >> active_win) & 1
                    if g_minimize_active == 0 and already_minimized == 0:
                        g_minimize_active = 1
                        g_minimize_progress = 0
                        g_minimize_win = active_win
                        needs_redraw = 1
                        serial_println("[WM] Minimizing window")
                if wm_shortcut == 8:
                    # W = close
                    if g_close_active == 0:
                        g_close_active = 1
                        g_close_progress = 0
                        g_close_win = active_win
                        needs_redraw = 1
                        serial_println("[WM] Closing window")
                if wm_shortcut == 9:
                    # R = restore
                    if g_minimize_states != 0:
                        g_minimize_states = 0
                        needs_redraw = 1
                        serial_println("[WM] Restored all windows")

                # Forward non-shortcut key presses to active app
                if wm_shortcut == 0:
                    var key_handled: u64 = 0
                    if scancode == 0x1C:  # Enter
                        if active_win == 0:
                            handle_terminal_enter()
                            key_handled = 1
                            needs_redraw = 1
                        if active_win == 1 and g_ed_editing == 1:
                            # Enter exits editing mode
                            g_ed_editing = 0
                            key_handled = 1
                            needs_redraw = 1
                        if active_win == 2 and g_browser_input_active == 1:
                            browser_navigate_url()
                            g_browser_input_active = 0
                            key_handled = 1
                            needs_redraw = 1
                    if scancode == 0x0E:  # Backspace
                        if active_win == 0:
                            handle_terminal_backspace()
                            key_handled = 1
                            needs_redraw = 1
                        if active_win == 1 and g_ed_editing == 1:
                            if g_ed_buf_len > 0:
                                g_ed_buf_len = g_ed_buf_len - 1
                                ed_clear_char(g_ed_buf_len)
                                g_editor_cursor_x = g_ed_buf_len
                            key_handled = 1
                            needs_redraw = 1
                        if active_win == 2 and g_browser_input_active == 1:
                            if g_browser_url_len > 0:
                                g_browser_url_len = g_browser_url_len - 1
                                browser_set_url_char(g_browser_url_len, 0)
                            key_handled = 1
                            needs_redraw = 1
                    if scancode == 0x01:  # Escape
                        if active_win == 1 and g_ed_editing == 1:
                            g_ed_editing = 0
                            key_handled = 1
                            needs_redraw = 1
                        if active_win == 2:
                            g_browser_input_active = 0
                            key_handled = 1
                            needs_redraw = 1
                    # Letter/symbol keys forwarded to active app
                    if key_handled == 0:
                        if active_win == 0:
                            val ch = scancode_to_ascii(scancode)
                            if ch != 0:
                                handle_terminal_char(ch)
                                key_handled = 1
                                needs_redraw = 1
                        if active_win == 1 and g_ed_editing == 1:
                            val ch = scancode_to_ascii(scancode)
                            if ch != 0 and g_ed_buf_len < 40:
                                ed_set_char(g_ed_buf_len, ch)
                                g_ed_buf_len = g_ed_buf_len + 1
                                g_editor_cursor_x = g_ed_buf_len
                                key_handled = 1
                                needs_redraw = 1
                        if active_win == 2 and g_browser_input_active == 1:
                            val ch = scancode_to_ascii(scancode)
                            if ch != 0:
                                if g_browser_url_len < 40:
                                    browser_set_url_char(g_browser_url_len, ch)
                                    g_browser_url_len = g_browser_url_len + 1
                                key_handled = 1
                                needs_redraw = 1

        # Poll mouse (PS/2 auxiliary device)
        if g_mouse_initialized == 1:
            val m_status = io_inb(0x64)
            if (m_status & 0x21) == 0x21:  # Bit 0=data ready, bit 5=mouse data
                val byte1 = io_inb(0x60)
                if (byte1 & 0x08) != 0:
                    # Valid packet header — read bytes 2+3
                    mouse_wait_read()
                    val byte2 = io_inb(0x60)
                    mouse_wait_read()
                    val byte3 = io_inb(0x60)

                    # Process mouse packet
                    g_mouse_prev_buttons = g_mouse_buttons
                    g_mouse_buttons = byte1 & 0x07  # Button bits

                    # X delta
                    var dx: u64 = byte2
                    if (byte1 & 0x10) != 0:
                        # Negative X: subtract from position
                        val neg_dx = 256 - dx
                        if g_mouse_x > neg_dx:
                            g_mouse_x = g_mouse_x - neg_dx
                        else:
                            g_mouse_x = 0
                    else:
                        g_mouse_x = g_mouse_x + dx
                        if g_mouse_x >= SCREEN_W:
                            g_mouse_x = SCREEN_W - 1

                    # Y delta (inverted for screen coordinates)
                    var dy: u64 = byte3
                    if (byte1 & 0x20) != 0:
                        # Negative Y (inverted = move down on screen)
                        val neg_dy = 256 - dy
                        g_mouse_y = g_mouse_y + neg_dy
                        if g_mouse_y >= SCREEN_H:
                            g_mouse_y = SCREEN_H - 1
                    else:
                        # Positive Y (inverted = move up on screen)
                        if g_mouse_y > dy:
                            g_mouse_y = g_mouse_y - dy
                        else:
                            g_mouse_y = 0

                    # Left click detection
                    val left_pressed = g_mouse_buttons & 1
                    val left_was = g_mouse_prev_buttons & 1

                    # Button just pressed — hit test for focus + start drag
                    if left_pressed == 1:
                        if left_was == 0:
                            serial_println("[WM] Mouse click")
                            # Hit test windows back-to-front (win2, win1, win0)
                            # Window 2 (Browser)
                            if g_mouse_x >= WIN2_X:
                                if g_mouse_x < WIN2_X + WIN2_W:
                                    if g_mouse_y >= WIN2_Y:
                                        if g_mouse_y < WIN2_Y + WIN2_H:
                                            if active_win != 2:
                                                active_win = 2
                                                animating = 1
                                                anim_start = anim_frame
                                                g_anim_progress = 0
                                            # Start drag if in title bar
                                            if g_mouse_y < WIN2_Y + TITLE_BAR_H:
                                                g_dragging = 3
                                                g_drag_offset_x = g_mouse_x - WIN2_X
                                                g_drag_offset_y = g_mouse_y - WIN2_Y
                            # Window 1 (Editor)
                            if g_dragging == 0:
                                if g_mouse_x >= WIN1_X:
                                    if g_mouse_x < WIN1_X + WIN1_W:
                                        if g_mouse_y >= WIN1_Y:
                                            if g_mouse_y < WIN1_Y + WIN1_H:
                                                if active_win != 1:
                                                    active_win = 1
                                                    animating = 1
                                                    anim_start = anim_frame
                                                    g_anim_progress = 0
                                                if g_mouse_y < WIN1_Y + TITLE_BAR_H:
                                                    g_dragging = 2
                                                    g_drag_offset_x = g_mouse_x - WIN1_X
                                                    g_drag_offset_y = g_mouse_y - WIN1_Y
                            # Window 0 (Terminal)
                            if g_dragging == 0:
                                if g_mouse_x >= WIN0_X:
                                    if g_mouse_x < WIN0_X + WIN0_W:
                                        if g_mouse_y >= WIN0_Y:
                                            if g_mouse_y < WIN0_Y + WIN0_H:
                                                if active_win != 0:
                                                    active_win = 0
                                                    animating = 1
                                                    anim_start = anim_frame
                                                    g_anim_progress = 0
                                                if g_mouse_y < WIN0_Y + TITLE_BAR_H:
                                                    g_dragging = 1
                                                    g_drag_offset_x = g_mouse_x - WIN0_X
                                                    g_drag_offset_y = g_mouse_y - WIN0_Y

                    # Dragging — update window position
                    if g_dragging != 0:
                        if left_pressed == 1:
                            if g_dragging == 1:
                                if g_mouse_x >= g_drag_offset_x:
                                    WIN0_X = g_mouse_x - g_drag_offset_x
                                if g_mouse_y >= g_drag_offset_y:
                                    WIN0_Y = g_mouse_y - g_drag_offset_y
                            if g_dragging == 2:
                                if g_mouse_x >= g_drag_offset_x:
                                    WIN1_X = g_mouse_x - g_drag_offset_x
                                if g_mouse_y >= g_drag_offset_y:
                                    WIN1_Y = g_mouse_y - g_drag_offset_y
                            if g_dragging == 3:
                                if g_mouse_x >= g_drag_offset_x:
                                    WIN2_X = g_mouse_x - g_drag_offset_x
                                if g_mouse_y >= g_drag_offset_y:
                                    WIN2_Y = g_mouse_y - g_drag_offset_y

                    # Propagate click to active window's content area
                    if g_dragging == 0:
                        if left_pressed == 1:
                            if left_was == 0:
                                # Compute local coordinates within the active window
                                var local_x: u64 = 0
                                var local_y: u64 = 0
                                var in_content: u64 = 0

                                if active_win == 0:
                                    if g_mouse_x >= WIN0_X:
                                        if g_mouse_x < WIN0_X + WIN0_W:
                                            if g_mouse_y >= WIN0_Y + TITLE_BAR_H:
                                                if g_mouse_y < WIN0_Y + WIN0_H:
                                                    local_x = g_mouse_x - WIN0_X
                                                    local_y = g_mouse_y - (WIN0_Y + TITLE_BAR_H)
                                                    in_content = 1
                                if active_win == 1:
                                    if g_mouse_x >= WIN1_X:
                                        if g_mouse_x < WIN1_X + WIN1_W:
                                            if g_mouse_y >= WIN1_Y + TITLE_BAR_H:
                                                if g_mouse_y < WIN1_Y + WIN1_H:
                                                    local_x = g_mouse_x - WIN1_X
                                                    local_y = g_mouse_y - (WIN1_Y + TITLE_BAR_H)
                                                    in_content = 1
                                if active_win == 2:
                                    if g_mouse_x >= WIN2_X:
                                        if g_mouse_x < WIN2_X + WIN2_W:
                                            if g_mouse_y >= WIN2_Y + TITLE_BAR_H:
                                                if g_mouse_y < WIN2_Y + WIN2_H:
                                                    local_x = g_mouse_x - WIN2_X
                                                    local_y = g_mouse_y - (WIN2_Y + TITLE_BAR_H)
                                                    in_content = 1

                                if in_content == 1:
                                    if active_win == 0:
                                        handle_terminal_click(local_x, local_y)
                                    if active_win == 1:
                                        handle_editor_click(local_x, local_y)
                                    if active_win == 2:
                                        handle_browser_click(local_x, local_y)
                                    needs_redraw = 1

                    # Button released — stop dragging
                    if left_pressed == 0:
                        if g_dragging != 0:
                            g_dragging = 0

                    needs_redraw = 1

        # Update cursor shape based on mouse position
        if g_mouse_initialized == 1:
            update_cursor_shape()

        # Update focus animation
        if animating == 1:
            val elapsed = anim_frame - anim_start
            if elapsed >= anim_duration:
                animating = 0
                g_anim_progress = 100
            else:
                g_anim_progress = (elapsed * 100) / anim_duration
            needs_redraw = 1

        # Minimize animation tick (8 frames = ~130ms at 60fps)
        if g_minimize_active == 1:
            g_minimize_progress = g_minimize_progress + 12
            if g_minimize_progress >= 100:
                g_minimize_progress = 100
                g_minimize_active = 0
                # Mark window as minimized
                g_minimize_states = g_minimize_states | (1 << g_minimize_win)
                # Cycle to next non-minimized window
                var next_win: u64 = (active_win + 1) % 3
                var search: u64 = 0
                while search < 3:
                    val next_min = (g_minimize_states >> next_win) & 1
                    if next_min == 0:
                        search = 3  # break
                    else:
                        next_win = (next_win + 1) % 3
                    search = search + 1
                active_win = next_win
                serial_println("[WM] Window minimized to dock")
            needs_redraw = 1

        # Close animation tick (6 frames = ~100ms)
        if g_close_active == 1:
            g_close_progress = g_close_progress + 16
            if g_close_progress >= 100:
                g_close_progress = 100
                g_close_active = 0
                # Mark window as minimized (same as minimize for now)
                g_minimize_states = g_minimize_states | (1 << g_close_win)
                active_win = (active_win + 1) % 3
            needs_redraw = 1

        # Redraw if needed
        if needs_redraw == 1:
            draw_desktop(active_win, theme)
            needs_redraw = 0
            idle_count = 0

        anim_frame = anim_frame + 1
        g_frame_count = g_frame_count + 1

        # Throttle: simple busy-wait to avoid 100% CPU spin
        # ~60fps: waste some cycles between frames when idle
        if animating == 0 and g_minimize_active == 0 and g_close_active == 0:
            idle_count = idle_count + 1
            # After settling, stop redrawing until next input
            var spin: u64 = 0
            while spin < 50000:
                spin = spin + 1

    serial_println("[WM] Window Manager shutting down")
