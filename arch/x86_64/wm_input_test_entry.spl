# SimpleOS WM Input Test Entry
#
# Boot-safe synthetic input test for the window-manager path.
# This intentionally avoids runtime string allocation and GUI helper calls
# so it can boot even when the older input-test entry path faults early.
#
# The test emits deterministic serial markers for click/drag transitions and
# exits through the QEMU debug port.

extern fn rt_port_inb(port: u64) -> u64
extern fn rt_port_outb(port: u64, value: u64)
extern fn rt_gui_set_fb(addr: u64, width: u64) -> u64
extern fn rt_gui_begin_frame(w: u64, h: u64, u1: u64, u2: u64) -> u64
extern fn rt_gui_blend_fill(xy: u64, wh: u64, color: u64, alpha: u64) -> u64
extern fn rt_gui_present(u1: u64, u2: u64, u3: u64, u4: u64) -> u64

use os.services.pcimgr.pcimgr.{pcimgr_init}

fn serial_data_port() -> u64:
    0x3F8

fn serial_lsr_port() -> u64:
    0x3FD

fn debug_exit_port() -> u64:
    0xF4

fn pack(hi: u64, lo: u64) -> u64:
    (hi << 32) | (lo & 0xFFFFFFFF)

fn serial_wait_ready():
    var guard: i64 = 100000
    while guard > 0:
        if (rt_port_inb(serial_lsr_port()) & 0x20) != 0:
            return
        guard = guard - 1

fn serial_put(ch: u64):
    serial_wait_ready()
    rt_port_outb(serial_data_port(), ch)

fn serial_newline():
    serial_put(13)
    serial_put(10)

