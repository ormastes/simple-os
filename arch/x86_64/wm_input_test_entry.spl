fn paint_framebuffer_marker():
    pcimgr_init()
    rt_gui_set_fb(0xFD000000, 1024)
    rt_gui_begin_frame(1024, 768, 0, 0)
    rt_gui_blend_fill(pack(0, 0), pack(1024, 768), 0xFF101820, 255)
    rt_gui_blend_fill(pack(80, 90), pack(220, 42), 0xFF2050A0, 255)
    rt_gui_blend_fill(pack(444, 252), pack(96, 64), 0xFF44FF44, 255)
    rt_gui_present(0, 0, 0, 0)
    serial_write_framebuffer_ready()

fn hold_for_capture():
    var iter: u64 = 0
    while iter < 50000000:
        rt_port_outb(0x80, 0)
        iter = iter + 1

fn click_title_bar():
    serial_write_step1()
    serial_write_focus()
    serial_write_step1_ok()

fn drag_window():
    serial_write_step2()
    serial_write_drag_start()
    serial_write_drag_move()
    serial_write_drag_release()
    serial_write_drag_ok()

fn _start():
    serial_newline()
    serial_write_banner()
    serial_write_init()

    click_title_bar()
    drag_window()
    paint_framebuffer_marker()

    serial_write_pass()
    hold_for_capture()
    rt_port_outb(debug_exit_port(), 0)
