#![allow(unnamed_duplicate_typed_args)]
# TLS 1.3 System Test — live handshake against rustls test server
#
# Boots all SimpleOS services, opens TCP to 10.0.2.2:4433 (QEMU gateway → host),
# performs a full TLS 1.3 handshake via tls13_connect, exchanges test messages,
# then exits QEMU.
#
# Usage:
#   # Start rustls test server on host:
#   cargo run --example server -- --port 4433
#   # Boot SimpleOS in QEMU:
#   qemu-system-x86_64 ... -netdev user,id=n0 -device virtio-net-pci,netdev=n0 ...

extern fn serial_println(msg: text)
extern fn rt_port_outb(port: u16, value: u8)
extern fn rt_net_socket(proto: i64) -> i64
extern fn rt_net_connect_host_tls(sock_fd: i64) -> i64
extern fn rt_net_close(sock_fd: i64) -> i64
extern fn rt_ipc_send_bytes(port: u64, method: u64, data: [u8]) -> i64
extern fn rt_ipc_recv_bytes(port: u64, max_len: i64) -> [u8]

# POSIX layer
use os.posix.fd_table.{fd_table_init}
use os.posix.async_io.{async_io_init}
use os.posix.signal_compat.{signal_init}

# Services
use os.kernel.boot.init_services.{init_all_services, services_network_ready}

# TLS 1.3
use os.tls13.mod.{tls13_connect, tls13_send, tls13_recv, tls13_close, Tls13ConnectResult}

var _pass_count: u32 = 0
var _fail_count: u32 = 0
val _NETSTACK_PORT: u64 = 2
val _NET_SOCKET: u64 = 1
val _NET_CONNECT: u64 = 4

fn _serial(s: text):
    serial_println(s)

fn _assert(condition: bool, name: text):
    if condition:
        _serial("[TEST PASS] {name}")
        _pass_count = _pass_count + 1
    else:
        _serial("[TEST FAIL: {name}]")
        _fail_count = _fail_count + 1

fn _push_i32(dst: [u8], value: i32):
    val raw = value as u32
    dst.push((raw & 0xFF).to_u8())
    dst.push(((raw >> 8) & 0xFF).to_u8())
    dst.push(((raw >> 16) & 0xFF).to_u8())
    dst.push(((raw >> 24) & 0xFF).to_u8())

fn _push_u32(dst: [u8], value: u32):
    val raw = value
    dst.push((raw & 0xFF).to_u8())
    dst.push(((raw >> 8) & 0xFF).to_u8())
    dst.push(((raw >> 16) & 0xFF).to_u8())
    dst.push(((raw >> 24) & 0xFF).to_u8())

fn _push_u16(dst: [u8], value: u16):
    val raw = value as u32
    dst.push((raw & 0xFF).to_u8())
    dst.push(((raw >> 8) & 0xFF).to_u8())

fn _read_i32(buf: [u8], offset: u64) -> i32:
    val b0 = buf[offset] as u32
    val b1 = buf[offset + 1] as u32
    val b2 = buf[offset + 2] as u32
    val b3 = buf[offset + 3] as u32
    (b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)) as i32

fn _net_socket_tcp() -> Result<i64, text>:
    val fd = rt_net_socket(1)
    if fd < 0:
        return Err("socket status {fd}")
    Ok(fd)

fn _net_connect(fd: i64, a: u8, b: u8, c: u8, d: u8, port: u16) -> Result<bool, text>:
    val _ip = (a as u32) | ((b as u32) << 8) | ((c as u32) << 16) | ((d as u32) << 24)
    val _port = port
    val status = rt_net_connect_host_tls(fd)
    if status < 0:
        return Err("connect status {status}")
    Ok(true)

fn _text_to_bytes(s: text) -> [u8]:
    var out: [u8] = []
    var i: u64 = 0
    while i < s.len():
        out.push(s.byte_at(i))
        i = i + 1
    out

# Check if haystack [u8] contains the ASCII bytes of needle text
fn _bytes_contains(haystack: [u8], needle: text) -> bool:
    val needle_bytes = _text_to_bytes(needle)
    val nlen = needle_bytes.len()
    val hlen = haystack.len()
    if nlen == 0:
        return true
    if nlen > hlen:
        return false
    var hi: u64 = 0
    while hi + nlen <= hlen:
        var match: bool = true
        var ni: u64 = 0
        while ni < nlen:
            if haystack[hi + ni] != needle_bytes[ni]:
                match = false
            ni = ni + 1
        if match:
            return true
        hi = hi + 1
    false

fn _start():
    _serial("")
    _serial("=== TLS 1.3 System Test ===")
    _serial("")

    # ----------------------------------------------------------------
    # Boot: POSIX layer + all services
    # ----------------------------------------------------------------
    fd_table_init()
    async_io_init()
    signal_init()
    _serial("[boot] POSIX layer initialized")

    init_all_services()

    if not services_network_ready():
        _serial("[TLS FAIL: network unavailable]")
        _serial("TLS system test: 0 passed, 1 failed")
        rt_port_outb(0xf4, 0u8)
        return

    _serial("[boot] Network ready")
    _serial("")

    # ----------------------------------------------------------------
    # Test 1: Open TCP socket
    # ----------------------------------------------------------------
    _serial("--- Test 1: TCP socket ---")
    val sock_result = _net_socket_tcp()
    if sock_result.is_err():
        _serial("  socket failed: {sock_result.unwrap_err()}")
        _serial("[TLS FAIL: socket creation failed]")
        _serial("TLS system test: {_pass_count} passed, {_fail_count} failed")
        rt_port_outb(0xf4, 0u8)
        return
    val tcp_fd = sock_result.unwrap()
    _serial("  socket fd returned: {tcp_fd}")
    _assert(tcp_fd >= 0, "TCP socket created (fd >= 0)")
    # ----------------------------------------------------------------
    # Test 2: Connect TCP to 10.0.2.2:4433 (QEMU gateway)
    # ----------------------------------------------------------------
    _serial("--- Test 2: TCP connect to 10.0.2.2:4433 ---")
    val connect_result = _net_connect(tcp_fd, 10u8, 0u8, 2u8, 2u8, 4433u16)
    if val Err(connect_err) = connect_result:
        _serial("  connect failed: {connect_err}")
        _assert(false, "TCP connect to 10.0.2.2:4433 succeeded")
        rt_net_close(tcp_fd)
        _serial("[TLS FAIL: TCP connect failed]")
        _serial("TLS system test: {_pass_count} passed, {_fail_count} failed")
        rt_port_outb(0xf4, 0u8)
        return
    if val Ok(_) = connect_result:
        pass
    _serial("  connect returned: ok")
    _assert(true, "TCP connect to 10.0.2.2:4433 succeeded")

    _serial("[boot] TCP connection established")

    # ----------------------------------------------------------------
    # Test 3: TLS 1.3 handshake
    # ----------------------------------------------------------------
    _serial("--- Test 3: TLS 1.3 handshake ---")
    val tls_result = tls13_connect(tcp_fd, "localhost")

    if val Tls13ConnectResult.Failed(reason) = tls_result:
        _serial("[TLS FAIL: handshake failed: {reason}]")
        _assert(false, "TLS 1.3 handshake completed")
        rt_net_close(tcp_fd)
        _serial("TLS system test: {_pass_count} passed, {_fail_count} failed")
        rt_port_outb(0xf4, 0u8)
        return

    if val Tls13ConnectResult.Connected(ctx) = tls_result:
        _assert(true, "TLS 1.3 handshake completed")
        _serial("[TLS HANDSHAKE COMPLETE]")

        # ------------------------------------------------------------
        # Test 4: Receive server greeting
        # ------------------------------------------------------------
        _serial("--- Test 4: Receive server greeting ---")
        val recv_result = tls13_recv(ctx)
        if not recv_result.ok:
            _serial("[TLS FAIL: recv failed: {recv_result.reason}]")
            _assert(false, "Server greeting receive succeeded")
            tls13_close(ctx)
            _serial("TLS system test: {_pass_count} passed, {_fail_count} failed")
            rt_port_outb(0xf4, 0u8)
            return
        val greeting_data = recv_result.data
        val ctx2 = recv_result.ctx
        _serial("  Received {greeting_data.len()} bytes from server")

        val greeting_ok = _bytes_contains(greeting_data, "Hello from rustls TLS 1.3")
        _assert(greeting_ok, "Server greeting contains 'Hello from rustls TLS 1.3'")

        if not greeting_ok:
            _serial("  WARNING: greeting did not match expected text")

        # ------------------------------------------------------------
        # Test 5: Send our greeting
        # ------------------------------------------------------------
        _serial("--- Test 5: Send client greeting ---")
        val send_bytes = _text_to_bytes("Hello from SimpleOS TLS 1.3")
        val send_result = tls13_send(ctx2, send_bytes)
        if not send_result.ok:
            _serial("[TLS FAIL: send failed: {send_result.reason}]")
            _assert(false, "Client greeting sent")
            tls13_close(ctx2)
            _serial("TLS system test: {_pass_count} passed, {_fail_count} failed")
            rt_port_outb(0xf4, 0u8)
            return
        val ctx3 = send_result.ctx
        _serial("  Sent {send_bytes.len()} bytes")
        _assert(send_bytes.len() > 0, "Client greeting sent")

        # ------------------------------------------------------------
        # Test 6: Close TLS connection
        # ------------------------------------------------------------
        _serial("--- Test 6: TLS close ---")
        val close_result = tls13_close(ctx3)
        _assert(close_result.ok, "TLS connection closed cleanly")
        if close_result.ok:
            _serial("  TLS close_notify sent, TCP closed")
        else:
            _serial("  TLS close failed: {close_result.reason}")

    # ----------------------------------------------------------------
    # Results
    # ----------------------------------------------------------------
    _serial("")
    _serial("TLS system test: {_pass_count} passed, {_fail_count} failed")
    if _fail_count == 0:
        _serial("ALL TLS SYSTEM TESTS PASSED")
    else:
        _serial("{_fail_count} TLS system tests FAILED")

    rt_port_outb(0xf4, 0u8)
