#![allow(unnamed_duplicate_typed_args)]
# x86_64 Browser Software Entry -- DOM/layout/paint/software raster smoke test
#
# Exercises the direct browser pipeline without BrowserRenderer, Engine2D,
# or backend_cuda:
#   BeDomNode -> layout_tree -> generate_paint_list ->
#   paint_commands_to_scene -> execute_scene_to_buffer

extern fn rt_port_inb(port: u16) -> u8
extern fn rt_port_outb(port: u16, value: u8)

use std.gc_async_mut.gpu.browser_engine.dom.{BeDomNode}
use std.gc_async_mut.gpu.browser_engine.layout.{layout_tree}
use std.gc_async_mut.gpu.browser_engine.paint.{generate_paint_list,
    paint_commands_to_scene}
use common.render_scene.executor.{execute_scene_to_buffer}

val VIEWPORT_W: i32 = 400
val VIEWPORT_H: i32 = 300
val BG_COLOR: u32 = 0xFFF5F5F5
val SERIAL_DATA: u16 = 0x3F8
val SERIAL_LSR: u16 = 0x3FD
val DEBUG_EXIT: u16 = 0xF4

fn serial_wait_ready():
    var guard: i64 = 100000
    while guard > 0:
        if (rt_port_inb(SERIAL_LSR) & 0x20) != 0:
            return
        guard = guard - 1

fn serial_put(ch: u8):
    rt_port_outb(SERIAL_DATA, ch)

fn serial_newline():
    serial_put(13)
    serial_put(10)

