fn build_dom() -> BeDomNode:
    var root = BeDomNode.element("div")
    root.set_style("background-color", "#f5f5f5")

    var green_box = BeDomNode.element("div")
    green_box.set_style("width", "200")
    green_box.set_style("height", "50")
    green_box.set_style("background-color", "#22aa44")
    root.add_child(green_box)

    var blue_box = BeDomNode.element("div")
    blue_box.set_style("width", "160")
    blue_box.set_style("height", "36")
    blue_box.set_style("margin-top", "8")
    blue_box.set_style("background-color", "#1d4ed8")
    root.add_child(blue_box)

    return root

fn init_buffer(width: i32, height: i32, bg: u32) -> [u32]:
    var buffer: [u32] = []
    var i: i32 = 0
    val total = width * height
    while i < total:
        buffer = buffer + [bg]
        i = i + 1
    return buffer

fn count_non_background_pixels(buffer: [u32], bg: u32) -> i32:
    var count: i32 = 0
    var i: i32 = 0
    while i < buffer.len():
        if buffer[i] != bg:
            count = count + 1
        i = i + 1
    return count

fn run_browser_pipeline() -> i32:
    val dom = build_dom()
    rt_port_outb(SERIAL_DATA, 99)

    val layout = layout_tree(dom, VIEWPORT_W, VIEWPORT_H)
    rt_port_outb(SERIAL_DATA, 100)

    val commands = generate_paint_list(layout)
    rt_port_outb(SERIAL_DATA, 101)

    val scene = paint_commands_to_scene(commands, VIEWPORT_W, VIEWPORT_H)
    rt_port_outb(SERIAL_DATA, 102)

    var buffer = init_buffer(VIEWPORT_W, VIEWPORT_H, BG_COLOR)
    rt_port_outb(SERIAL_DATA, 103)
    execute_scene_to_buffer(scene, buffer, VIEWPORT_W, VIEWPORT_H)
    rt_port_outb(SERIAL_DATA, 104)

    val visible = count_non_background_pixels(buffer, BG_COLOR)
    return visible

fn browser_soft_leaf_probe() -> i32:
    rt_port_outb(SERIAL_DATA, 98)
    return 1

fn spl_start():
    write_browser_start()
    val leaf_ok = browser_soft_leaf_probe()
    if leaf_ok == 0:
        write_browser_fail()
        rt_port_outb(DEBUG_EXIT, 0)
        return

    val visible = run_browser_pipeline()
    if visible > 0:
        write_browser_pass()
    else:
        write_browser_fail()
    rt_port_outb(DEBUG_EXIT, 0)
