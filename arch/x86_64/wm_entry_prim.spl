# Layout engine
extern fn rt_layout_reset(u1: u64, u2: u64, u3: u64, u4: u64)
extern fn rt_layout_add(type_: u64, parent: u64, u1: u64, u2: u64) -> u64
extern fn rt_layout_set_size(id: u64, w_spec: u64, h_spec: u64, u: u64)
extern fn rt_layout_set_padding(id: u64, lr: u64, tb: u64, u: u64)
extern fn rt_layout_set_props(id: u64, spacing: u64, align: u64, u: u64)
extern fn rt_layout_compute(wh: u64, u1: u64, u2: u64, u3: u64)
extern fn rt_layout_get(id: u64, u1: u64, u2: u64, u3: u64) -> u64
extern fn rt_layout_get_size(id: u64, u1: u64, u2: u64, u3: u64) -> u64

# Pack two u32 values into one u64 (high|low)
fn pack(hi: u64, lo: u64) -> u64:
    (hi << 32) | (lo & 0xFFFFFFFF)

