# ===========================================================================
# Rendering Helpers
# ===========================================================================

fn fill(x: u64, y: u64, w: u64, h: u64, color: u64):
    rt_gui_shadow_fill(pack(x, y), pack(w, h), color, 0)

fn blend(x: u64, y: u64, w: u64, h: u64, color: u64, alpha: u64):
    rt_gui_blend_fill(pack(x, y), pack(w, h), color, alpha)

fn blur(x: u64, y: u64, w: u64, h: u64, radius: u64):
    rt_gui_box_blur(pack(x, y), pack(w, h), radius, 0)

fn grad_v(x: u64, y: u64, w: u64, h: u64, c1: u64, c2: u64):
    rt_gui_gradient_v(pack(x, y), pack(w, h), c1, c2)

fn grad_h(x: u64, y: u64, w: u64, h: u64, c1: u64, c2: u64):
    rt_gui_gradient_h(pack(x, y), pack(w, h), c1, c2)

fn shadow(x: u64, y: u64, w: u64, h: u64, blur_r: u64, alpha: u64, offset: u64):
    rt_gui_shadow(pack(x, y), pack(w, h), pack(blur_r, alpha), offset)

fn rrect(x: u64, y: u64, w: u64, h: u64, color: u64, radius: u64, alpha: u64):
    rt_gui_rounded_rect(pack(x, y), pack(w, h), pack(color, radius), alpha)

fn rrect_top(x: u64, y: u64, w: u64, h: u64, color: u64, radius: u64, alpha: u64):
    rt_gui_rounded_rect_top(pack(x, y), pack(w, h), pack(color, radius), alpha)

fn circle(cx: u64, cy: u64, diameter: u64, color: u64, alpha: u64):
    rt_gui_filled_circle(pack(cx, cy), pack(diameter, color), alpha, 0)

fn rrect_aa(x: u64, y: u64, w: u64, h: u64, color: u64, radius: u64, alpha: u64):
    rt_gui_rounded_rect_aa(pack(x, y), pack(w, h), pack(color, radius), alpha)

fn line(x1: u64, y1: u64, x2: u64, y2: u64, color: u64, thick: u64, alpha: u64):
    rt_gui_line(pack(x1, y1), pack(x2, y2), pack(color, thick), alpha)

fn ring(cx: u64, cy: u64, diameter: u64, thick: u64, color: u64, alpha: u64):
    rt_gui_ring(pack(cx, cy), pack(diameter, thick), pack(color, 0), alpha)

fn grad_rect(x: u64, y: u64, w: u64, h: u64, c1: u64, radius: u64, c2: u64, alpha: u64):
    rt_gui_gradient_rect(pack(x, y), pack(w, h), pack(c1, radius), pack(c2, alpha))

fn noise(x: u64, y: u64, w: u64, h: u64, intensity: u64):
    rt_gui_noise_blend(pack(x, y), pack(w, h), intensity, 0)

# ===========================================================================
# Text Rendering Helpers
# ===========================================================================

fn pack8(a: u64, b: u64, c: u64, d: u64, e: u64, f: u64, g: u64, h: u64) -> u64:
    (a << 56) | (b << 48) | (c << 40) | (d << 32) | (e << 24) | (f << 16) | (g << 8) | h

fn draw_label(x: u64, y: u64, color: u64, alpha: u64, chars: u64, len: u64):
    rt_gui_set_text_buf(chars, 0, 0, 0)
    rt_gui_draw_text_buf(pack(x, y), pack(color, len), alpha, 0)

fn draw_label_shadow(x: u64, y: u64, color: u64, alpha: u64, chars: u64, len: u64, shadow_a: u64):
    rt_gui_set_text_buf(chars, 0, 0, 0)
    rt_gui_draw_text_shadow(pack(x, y), pack(color, len), alpha, shadow_a)

fn draw_label_bold(x: u64, y: u64, color: u64, alpha: u64, chars: u64, len: u64):
    rt_gui_set_text_buf(chars, 0, 0, 0)
    rt_gui_draw_text_bold(pack(x, y), pack(color, len), alpha, 0)

fn draw_label_2x(x: u64, y: u64, color: u64, alpha: u64, chars: u64, len: u64, shadow_a: u64):
    rt_gui_set_text_buf(chars, 0, 0, 0)
    rt_gui_draw_text_2x(pack(x, y), pack(color, len), alpha, shadow_a)

fn draw_label_outline(x: u64, y: u64, color: u64, alpha: u64, chars: u64, len: u64, outline_a: u64):
    rt_gui_set_text_buf(chars, 0, 0, 0)
    rt_gui_draw_text_outline(pack(x, y), pack(color, len), alpha, outline_a)

fn draw_label_vector(x: u64, y: u64, color: u64, alpha: u64, chars: u64, len: u64, pixel_height: u64):
    rt_gui_set_text_buf(chars, 0, 0, 0)
    val size_and_len = (pixel_height << 16) | (len & 0xFFFF)
    rt_gui_draw_text_vector(pack(x, y), pack(color, size_and_len), alpha, 0)

# ===========================================================================
# Layout Engine Constants + Helpers
# ===========================================================================

val LT_HSTACK: u64 = 1
val LT_VSTACK: u64 = 2
val LT_ZSTACK: u64 = 3
val SM_FIXED: u64 = 0
val SM_FILL: u64 = 1
val SM_AUTO: u64 = 2
val ALIGN_START: u64 = 0
val ALIGN_CENTER: u64 = 1
val ALIGN_END: u64 = 2

fn layout_fixed(size: u64) -> u64:
    pack(SM_FIXED, size)

fn layout_fill(weight: u64) -> u64:
    pack(SM_FILL, weight)

fn layout_auto() -> u64:
    pack(SM_AUTO, 0)

fn layout_x(id: u64) -> u64:
    rt_layout_get(id, 0, 0, 0) >> 32

fn layout_y(id: u64) -> u64:
    rt_layout_get(id, 0, 0, 0) & 0xFFFFFFFF

fn layout_w(id: u64) -> u64:
    rt_layout_get_size(id, 0, 0, 0) >> 32

fn layout_h(id: u64) -> u64:
    rt_layout_get_size(id, 0, 0, 0) & 0xFFFFFFFF

# ===========================================================================
# Theme-Aware Color Getters
# ===========================================================================

fn bg_top(theme: u64) -> u64:
    if theme == 0: DARK_BG_TOP
    else: LIGHT_BG_TOP

fn bg_bot(theme: u64) -> u64:
    if theme == 0: DARK_BG_BOT
    else: LIGHT_BG_BOT

fn surface(theme: u64) -> u64:
    if theme == 0: DARK_SURFACE
    else: LIGHT_SURFACE

fn surface_a(theme: u64) -> u64:
    if theme == 0: DARK_SURFACE_A
    else: LIGHT_SURFACE_A

fn elevated(theme: u64) -> u64:
    if theme == 0: DARK_ELEVATED
    else: LIGHT_ELEVATED

fn elevated_a(theme: u64) -> u64:
    if theme == 0: DARK_ELEVATED_A
    else: LIGHT_ELEVATED_A

fn border_c(theme: u64) -> u64:
    if theme == 0: DARK_BORDER
    else: LIGHT_BORDER

fn border_a(theme: u64) -> u64:
    if theme == 0: DARK_BORDER_A
    else: LIGHT_BORDER_A

fn accent(theme: u64) -> u64:
    if theme == 0: DARK_ACCENT
    else: LIGHT_ACCENT

fn accent2(theme: u64) -> u64:
    if theme == 0: DARK_ACCENT2
    else: LIGHT_ACCENT2

fn shadow_a(theme: u64) -> u64:
    if theme == 0: DARK_SHADOW_A
    else: LIGHT_SHADOW_A

fn text_c(theme: u64) -> u64:
    if theme == 0: DARK_TEXT
    else: LIGHT_TEXT

fn text_sec(theme: u64) -> u64:
    if theme == 0: DARK_TEXT_SEC
    else: LIGHT_TEXT_SEC

# ===========================================================================
# WM Chrome Stylesheet
# ===========================================================================

val CSS_CHROME_TITLEBAR: u64 = 1
val CSS_CHROME_MENUBAR: u64 = 2
val CSS_CHROME_DOCK: u64 = 3

fn chrome_radius(role: u64) -> u64:
    if role == CSS_CHROME_TITLEBAR: return WIN_CORNER_RADIUS
    if role == CSS_CHROME_MENUBAR: return 0
    if role == CSS_CHROME_DOCK: return DOCK_CORNER_RADIUS
    return 8

fn chrome_blur_radius(role: u64) -> u64:
    if role == CSS_CHROME_TITLEBAR: return BLUR_SUBTLE
    if role == CSS_CHROME_MENUBAR: return BLUR_ELEVATED
    if role == CSS_CHROME_DOCK: return BLUR_ELEVATED
    return BLUR_SUBTLE

fn chrome_surface_alpha(theme: u64, role: u64) -> u64:
    if role == CSS_CHROME_TITLEBAR: return elevated_a(theme)
    if role == CSS_CHROME_MENUBAR: return elevated_a(theme)
    if role == CSS_CHROME_DOCK: return surface_a(theme)
    return surface_a(theme)

fn chrome_vibrancy_alpha(role: u64) -> u64:
    if role == CSS_CHROME_TITLEBAR: return 10
    if role == CSS_CHROME_MENUBAR: return 5
    if role == CSS_CHROME_DOCK: return 6
    return 4

fn chrome_topline_alpha(role: u64) -> u64:
    if role == CSS_CHROME_TITLEBAR: return 30
    if role == CSS_CHROME_MENUBAR: return 35
    if role == CSS_CHROME_DOCK: return 35
    return 20

fn chrome_border_alpha(theme: u64, role: u64) -> u64:
    val base = border_a(theme)
    if role == CSS_CHROME_TITLEBAR: return base + 15
    if role == CSS_CHROME_MENUBAR: return 38
    if role == CSS_CHROME_DOCK: return base
    return base

fn chrome_draw_surface(role: u64, x: u64, y: u64, w: u64, h: u64, theme: u64):
    """Reusable chrome surface renderer; acts like shared CSS class styles."""
    val blur_r = chrome_blur_radius(role)
    blur(x, y, w, h, blur_r)
    if role == CSS_CHROME_MENUBAR:
        blur(x, y, w, h, 10)
    else:
        if role == CSS_CHROME_DOCK:
            blur(x, y, w, h, 12)
            blur(x, y, w, h, 6)
            blur(x, y, w, h, 4)

    blend(x, y, w, h, accent(theme), chrome_vibrancy_alpha(role))
    blend(x, y, w, h, 0x004080FF, 12)
    if role != CSS_CHROME_DOCK:
        blend(x, y, w, h, 0x00FF6B8A, 3)

    if role == CSS_CHROME_TITLEBAR:
        grad_rect(x, y, w, h, elevated(theme), chrome_radius(role), surface(theme), chrome_surface_alpha(theme, role))
        val top_h = h * 40 / 100
        val bot_start = h * 70 / 100
        val bot_h = h - bot_start
        blend(x + 1, y, w - 2, top_h, 0x00FFFFFF, 12)
        blend(x + 1, y + bot_start, w - 2, bot_h, 0x00000000, 8)
        noise(x + 1, y + 1, w - 2, h - 1, 1)
    else:
        grad_v(x, y, w, h, elevated(theme), surface(theme))
        blend(x, y, w, h / 2, 0x00FFFFFF, 8)
        blend(x, y + h / 2, w, h / 2, 0x00000000, 8)
        if role == CSS_CHROME_DOCK:
            rrect(x, y, w, h, surface(theme), chrome_radius(role), chrome_surface_alpha(theme, role))
            rrect(x + 1, y + 1, w - 2, h - 2, 0x00FFFFFF, chrome_radius(role) - 1, 10)
            blend(x + 2, y + 2, w - 4, h - 4, 0x00FFFFFF, 15)
        else:
            rrect_aa(x, y, w, h, surface(theme), chrome_radius(role), chrome_surface_alpha(theme, role))

    blend(x + 1, y + 1, w - 2, 1, 0x00FFFFFF, chrome_topline_alpha(role))
    if role == CSS_CHROME_DOCK:
        rrect(x, y, w, h, border_c(theme), chrome_radius(role), chrome_border_alpha(theme, role))
    else:
        blend(x, y + h - 1, w, 1, border_c(theme), chrome_border_alpha(theme, role))

fn chrome_draw_menu_item(x: u64, y: u64, w: u64, h: u64, theme: u64, is_active: u64, chars: u64, len: u64):
    if is_active == 1:
        rrect_aa(x - 2, y - 1, w + 4, h + 2, text_c(theme), 4, 25)
        blend(x - 2, y - 1, w + 4, h + 2, accent(theme), 8)
        blend(x, y + h - 2, w, 1, accent(theme), 120)
        blend(x, y + h, w, 1, accent(theme), 40)
    draw_label_vector(x + 2, y, text_c(theme), 220, chars, len, 14)

fn chrome_draw_toolbar_action(x: u64, y: u64, w: u64, h: u64, theme: u64, is_primary: u64):
    var bg_color = surface(theme)
    var bg_alpha: u64 = 60
    if is_primary == 1:
        bg_color = accent(theme)
        bg_alpha = 80
    rrect_aa(x, y, w, h, bg_color, 4, bg_alpha)
    rrect_aa(x, y, w, h, border_c(theme), 4, 20)
    blend(x + 1, y, w - 2, 1, 0x00FFFFFF, 15)

fn chrome_draw_dock_indicator(cx: u64, cy: u64, color: u64, is_focused: u64):
    circle(cx - 1, cy - 1, 8, color, 40)
    circle(cx, cy, 6, color, 220)
    if is_focused == 1:
        circle(cx, cy, 6, 0x00FFFFFF, 140)

fn chrome_draw_divider(x: u64, y: u64, h: u64, theme: u64, alpha: u64):
    blend(x, y, 1, h, border_c(theme), alpha)
