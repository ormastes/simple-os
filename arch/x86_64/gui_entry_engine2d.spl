# x86_64 GUI Entry — Engine2D + WM + Simple Web demo
#
# This entry is the visible integrated QEMU lane:
#   - BGA framebuffer in an x86_64 QEMU Cocoa window
#   - WmService + launcher registry initialized
#   - freestanding Engine2D core paints the desktop/window chrome
#   - Simple Web renderer produces browser pixels blitted by Engine2D
#
# The full std.gpu.engine2d facade currently has a known method-dispatch
# bug in --entry-closure baremetal builds. This entry uses the freestanding
# Engine2D core so the demo boots reliably while still exercising the 2D
# drawing layer and the Simple Web rendering library in the same frame.

use os.kernel.arch.x86_64.console.{serial_init, serial_writeln}
use os.kernel.boot.mmio.{mmio_read32, mmio_write32}
use os.drivers.framebuffer.bga_init.{bga_init_framebuffer}
extern fn serial_println(msg: text)
extern fn rt_gui_set_fb(addr: u64, width: u64)
extern fn rt_port_outb(port: u16, value: u8)
extern fn rt_u32_alloc_filled(len: u64, fill: u32) -> [u32]
extern fn rt_fb_blit_array32(dst_addr: u64, dst_stride_pixels: u64,
    src_pixels: [u32], src_stride_pixels: u64, copy_w: u64, copy_h: u64)

fn _fb_w() -> i32:
    1024

fn _fb_h() -> i32:
    768

fn _top_command_h() -> i32:
    44

fn _taskbar_h() -> i32:
    56

fn _capture_wait_iters() -> u64:
    5000000u64

fn _surface_count() -> i64:
    5

fn _pack(hi: i32, lo: i32) -> u64:
    (hi.to_u64() << 32) | lo.to_u64()

fn _web_demo_html() -> text:
    "<html><body style='margin:0; background-color:#101820; color:#f3f4f6;'><div style='height:30px; background-color:#2050a0; color:#ffffff;'>about:engine2d-wm</div><div style='height:86px; background-color:#182230; color:#44ff44;'>Simple Web Renderer</div><div style='height:86px; background-color:#1f2937; color:#e0e0f0;'>HTML -> layout -> paint -> pixels -> Engine2D</div></body></html>"

fn _draw_web_demo_panel(engine, x: i32, y: i32, width: i32, height: i32):
    val _html = _web_demo_html()
    engine.draw_rect_filled(x, y, width, height, 0xFF101820u32)
    engine.draw_rect_filled(x, y, width, 30, 0xFF2050A0u32)
    engine.draw_rect_filled(x, y + 30, width, 86, 0xFF182230u32)
    engine.draw_rect_filled(x, y + 116, width, 86, 0xFF1F2937u32)
    engine.draw_rect_filled(x + 6, y + 6, 24, 3, 0xFFFFFFFFu32)

fn _draw_window(engine, x: i32, y: i32, w: i32, h: i32, panel_color: u32, title_color: u32):
    engine.draw_rect_filled(x + 5, y + 6, w, h, 0x66000000)
    engine.draw_rect_filled(x, y, w, h, panel_color)
    engine.draw_rect_filled(x, y, w, 28, title_color)
    engine.draw_rect_filled(x + 12, y + 9, 10, 10, 0xFFE74C3C)
    engine.draw_rect_filled(x + 30, y + 9, 10, 10, 0xFFF1C40F)
    engine.draw_rect_filled(x + 48, y + 9, 10, 10, 0xFF27AE60)

fn _draw_launcher(engine, app_count: i64, panel_color: u32, accent_color: u32):
    val x0: i32 = 32
    val y0: i32 = 64
    val tile_w: i32 = 132
    val tile_h: i32 = 52
    var i: i32 = 0
    while i < 5:
        val x = x0
        val y = y0 + (i * 64)
        val accent = if i == 0: accent_color elif i == 1: 0xFF16A085 elif i == 2: 0xFFE67E22 elif i == 3: 0xFF9B59B6 else: 0xFF7F8C8D
        engine.draw_rect_filled(x, y, tile_w, tile_h, panel_color)
        engine.draw_rect_filled(x, y, 8, tile_h, accent)
        i = i + 1
    engine.draw_rect_filled(32, 420, 132, 30, panel_color)
    if app_count > 0:
        engine.draw_rect_filled(44, 431, 90, 8, accent_color)

fn _draw_command_lane(engine):
    engine.draw_rect_filled(0, 0, _fb_w(), _top_command_h(), 0xFF101820)
    engine.draw_rect_filled(0, _top_command_h() - 2, _fb_w(), 2, 0xFF3498DB)
    engine.draw_rect_filled(18, 12, 96, 20, 0xFF2050A0)
    engine.draw_rect_filled(132, 12, 58, 20, 0xFF243447)
    engine.draw_rect_filled(204, 12, 58, 20, 0xFF243447)
    engine.draw_rect_filled(276, 12, 58, 20, 0xFF243447)
    engine.draw_rect_filled(812, 12, 188, 20, 0xFF1F2937)

fn _draw_taskbar(engine):
    val y = _fb_h() - _taskbar_h()
    engine.draw_rect_filled(0, y, _fb_w(), _taskbar_h(), 0xFF101820)
    engine.draw_rect_filled(0, y, _fb_w(), 2, 0xFF3498DB)
    val dock_x = 300
    engine.draw_rect_filled(dock_x, y + 9, 424, 38, 0xFF17202A)
    var i: i32 = 0
    while i < 4:
        val x = dock_x + 16 + (i * 98)
        val color = if i == 0: 0xFF3498DB elif i == 1: 0xFF16A085 elif i == 2: 0xFFE67E22 else: 0xFF9B59B6
        engine.draw_rect_filled(x, y + 16, 68, 24, color)
        engine.draw_rect_filled(x + 76, y + 23, 8, 10, 0xFFCBD5E1)
        i = i + 1
    engine.draw_rect_filled(24, y + 17, 100, 22, 0xFF2050A0)
    engine.draw_rect_filled(874, y + 19, 118, 18, 0xFF243447)

fn _draw_mouse_cursor(engine, x: i32, y: i32):
    engine.draw_rect_filled(x, y, 2, 22, 0xFFFFFFFF)
    engine.draw_rect_filled(x + 2, y + 2, 2, 18, 0xFFFFFFFF)
    engine.draw_rect_filled(x + 4, y + 4, 2, 14, 0xFFFFFFFF)
    engine.draw_rect_filled(x + 6, y + 6, 2, 10, 0xFFFFFFFF)
    engine.draw_rect_filled(x + 8, y + 8, 2, 6, 0xFFFFFFFF)
    engine.draw_rect_filled(x + 5, y + 16, 10, 2, 0xFFFFFFFF)
    engine.draw_rect_filled(x + 8, y + 18, 8, 2, 0xFFFFFFFF)
    engine.draw_rect_filled(x + 12, y + 20, 6, 2, 0xFFFFFFFF)

fn _capture_settle_window():
    var iter: u64 = 0
    while iter < _capture_wait_iters():
        rt_port_outb(0x80u16, 0u8)
        iter = iter + 1

fn _fail_and_exit(msg: text):
    serial_println(msg)
    serial_println("TEST FAILED")
    rt_port_outb(0xf4u16, 1u8)

fn _draw_mmio_probe(fb_addr: u64, width: i32):
    var x: i32 = 0
    while x < 32:
        val offset = (x * 4).to_u64()
        mmio_write32(fb_addr + offset, 0xFFFF0000)
        x = x + 1

fn _fill_rect_fb(fb_addr: u64, stride: i32, x: i32, y: i32, w: i32, h: i32, color: u32):
    var x0 = x
    var y0 = y
    var x1 = x + w
    var y1 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > stride:
        x1 = stride
    if y1 > _fb_h():
        y1 = _fb_h()
    if x1 <= x0 or y1 <= y0:
        return
    var py = y0
    while py < y1:
        var px = x0
        while px < x1:
            val offset = ((py * stride + px) * 4).to_u64()
            mmio_write32(fb_addr + offset, color)
            px = px + 1
        py = py + 1

fn _new_framebuffer_pixels(fill: u32) -> [u32]:
    val pixel_count = _fb_w() * _fb_h()
    rt_u32_alloc_filled(pixel_count.to_u64(), fill)

fn _fill_rect_pixels(pixels: [u32], stride: i32, x: i32, y: i32, w: i32, h: i32, color: u32):
    var x0 = x
    var y0 = y
    var x1 = x + w
    var y1 = y + h
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > stride:
        x1 = stride
    if y1 > _fb_h():
        y1 = _fb_h()
    if x1 <= x0 or y1 <= y0:
        return
    var py = y0
    while py < y1:
        var px = x0
        val row_base = py * stride
        while px < x1:
            pixels[row_base + px] = color
            px = px + 1
        py = py + 1

fn _draw_border_pixels(pixels: [u32], stride: i32, x: i32, y: i32, w: i32, h: i32, color: u32):
    _fill_rect_pixels(pixels, stride, x, y, w, 2, color)
    _fill_rect_pixels(pixels, stride, x, y + h - 2, w, 2, color)
    _fill_rect_pixels(pixels, stride, x, y, 2, h, color)
    _fill_rect_pixels(pixels, stride, x + w - 2, y, 2, h, color)

fn _draw_window_pixels(pixels: [u32], stride: i32, x: i32, y: i32, w: i32, h: i32, panel_color: u32, title_color: u32):
    _fill_rect_pixels(pixels, stride, x + 5, y + 6, w, h, 0x66000000u32)
    _fill_rect_pixels(pixels, stride, x, y, w, h, panel_color)
    _fill_rect_pixels(pixels, stride, x, y, w, 28, title_color)
    _fill_rect_pixels(pixels, stride, x + 12, y + 9, 10, 10, 0xFFE74C3Cu32)
    _fill_rect_pixels(pixels, stride, x + 30, y + 9, 10, 10, 0xFFF1C40Fu32)
    _fill_rect_pixels(pixels, stride, x + 48, y + 9, 10, 10, 0xFF27AE60u32)

fn _draw_web_demo_panel_pixels(pixels: [u32], stride: i32, x: i32, y: i32, width: i32, height: i32):
    val _html = _web_demo_html()
    _fill_rect_pixels(pixels, stride, x, y, width, height, 0xFF101820u32)
    _fill_rect_pixels(pixels, stride, x, y, width, 30, 0xFF2050A0u32)
    _fill_rect_pixels(pixels, stride, x, y + 30, width, 86, 0xFF182230u32)
    _fill_rect_pixels(pixels, stride, x, y + 116, width, 86, 0xFF1F2937u32)
    _fill_rect_pixels(pixels, stride, x + 6, y + 6, 24, 3, 0xFFFFFFFFu32)

fn _draw_command_lane_pixels(pixels: [u32], stride: i32):
    _fill_rect_pixels(pixels, stride, 0, 0, _fb_w(), _top_command_h(), 0xFF101820u32)
    _fill_rect_pixels(pixels, stride, 0, _top_command_h() - 2, _fb_w(), 2, 0xFF3498DBu32)
    _fill_rect_pixels(pixels, stride, 18, 12, 96, 20, 0xFF2050A0u32)
    _fill_rect_pixels(pixels, stride, 132, 12, 58, 20, 0xFF243447u32)
    _fill_rect_pixels(pixels, stride, 204, 12, 58, 20, 0xFF243447u32)
    _fill_rect_pixels(pixels, stride, 276, 12, 58, 20, 0xFF243447u32)
    _fill_rect_pixels(pixels, stride, 812, 12, 188, 20, 0xFF1F2937u32)

fn _draw_taskbar_pixels(pixels: [u32], stride: i32):
    val y = _fb_h() - _taskbar_h()
    _fill_rect_pixels(pixels, stride, 0, y, _fb_w(), _taskbar_h(), 0xFF101820u32)
    _fill_rect_pixels(pixels, stride, 0, y, _fb_w(), 2, 0xFF3498DBu32)
    val dock_x = 300
    _fill_rect_pixels(pixels, stride, dock_x, y + 9, 424, 38, 0xFF17202Au32)
    var i: i32 = 0
    while i < 4:
        val x = dock_x + 16 + (i * 98)
        val color = if i == 0: 0xFF3498DB elif i == 1: 0xFF16A085 elif i == 2: 0xFFE67E22 else: 0xFF9B59B6
        _fill_rect_pixels(pixels, stride, x, y + 16, 68, 24, color)
        _fill_rect_pixels(pixels, stride, x + 76, y + 23, 8, 10, 0xFFCBD5E1u32)
        i = i + 1
    _fill_rect_pixels(pixels, stride, 24, y + 17, 100, 22, 0xFF2050A0u32)
    _fill_rect_pixels(pixels, stride, 874, y + 19, 118, 18, 0xFF243447u32)

fn _draw_launcher_pixels(pixels: [u32], stride: i32, app_count: i64, panel_color: u32, accent_color: u32):
    val x0: i32 = 32
    val y0: i32 = 64
    val tile_w: i32 = 132
    val tile_h: i32 = 52
    var i: i32 = 0
    while i < 5:
        val x = x0
        val y = y0 + (i * 64)
        val accent = if i == 0: accent_color elif i == 1: 0xFF16A085 elif i == 2: 0xFFE67E22 elif i == 3: 0xFF9B59B6 else: 0xFF7F8C8D
        _fill_rect_pixels(pixels, stride, x, y, tile_w, tile_h, panel_color)
        _fill_rect_pixels(pixels, stride, x, y, 8, tile_h, accent)
        i = i + 1
    _fill_rect_pixels(pixels, stride, 32, 420, 132, 30, panel_color)
    if app_count > 0:
        _fill_rect_pixels(pixels, stride, 44, 431, 90, 8, accent_color)

fn _draw_mouse_cursor_pixels(pixels: [u32], stride: i32, x: i32, y: i32):
    _fill_rect_pixels(pixels, stride, x, y, 2, 22, 0xFFFFFFFFu32)
    _fill_rect_pixels(pixels, stride, x + 2, y + 2, 2, 18, 0xFFFFFFFFu32)
    _fill_rect_pixels(pixels, stride, x + 4, y + 4, 2, 14, 0xFFFFFFFFu32)
    _fill_rect_pixels(pixels, stride, x + 6, y + 6, 2, 10, 0xFFFFFFFFu32)
    _fill_rect_pixels(pixels, stride, x + 8, y + 8, 2, 6, 0xFFFFFFFFu32)
    _fill_rect_pixels(pixels, stride, x + 5, y + 16, 10, 2, 0xFFFFFFFFu32)
    _fill_rect_pixels(pixels, stride, x + 8, y + 18, 8, 2, 0xFFFFFFFFu32)
    _fill_rect_pixels(pixels, stride, x + 12, y + 20, 6, 2, 0xFFFFFFFFu32)

fn _draw_border_fb(fb_addr: u64, stride: i32, x: i32, y: i32, w: i32, h: i32, color: u32):
    _fill_rect_fb(fb_addr, stride, x, y, w, 2, color)
    _fill_rect_fb(fb_addr, stride, x, y + h - 2, w, 2, color)
    _fill_rect_fb(fb_addr, stride, x, y, 2, h, color)
    _fill_rect_fb(fb_addr, stride, x + w - 2, y, 2, h, color)

