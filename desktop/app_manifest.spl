# App Manifest — Application Metadata for Launcher
#
# Defines application entries for the desktop app launcher.
# Manifests can be loaded from /usr/share/apps/*.sdn or
# returned as built-in defaults.
#
# MDSOC: feature dimension, desktop layer

# =========================================================================
# App Manifest
# =========================================================================

struct AppManifest:
    """Application manifest for the desktop launcher."""
    name: text
    description: text
    category: text          # "System", "Utilities", "Development", "Settings"
    binary: text            # Path to binary
    capabilities: [text]    # Required capabilities
    icon: text              # Icon identifier (text label for now)

# =========================================================================
# Manifest Loading
# =========================================================================

fn load_app_manifests() -> [AppManifest]:
    """Load application manifests.

    Returns built-in defaults plus any found in /usr/share/apps/.
    """
    # Built-in applications
    var manifests = default_manifests()

    # In a full OS, we would also scan /usr/share/apps/*.sdn
    # and parse each file into an AppManifest.
    # For now, return built-in defaults only.
    manifests

fn default_manifests() -> [AppManifest]:
