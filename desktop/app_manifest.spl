# =========================================================================
# Search
# =========================================================================

fn search_apps(manifests: [AppManifest], query: text) -> [AppManifest]:
    """Search manifests by name or description."""
    if query == "":
        return manifests
    var results: [AppManifest] = []
    val q_lower = query.to_lower()
    for m in manifests:
        if m.name.to_lower().contains(q_lower) or m.description.to_lower().contains(q_lower):
            results = results.push(m)
    results
