    [
        AppManifest(
            name: "Terminal",
            description: "VT100/ANSI terminal emulator",
            category: "System",
            binary: "/sys/apps/terminal",
            capabilities: ["FileRead(/)", "FileWrite(/home)"],
            icon: "term"
        ),
        AppManifest(
            name: "Shell",
            description: "Interactive command shell",
